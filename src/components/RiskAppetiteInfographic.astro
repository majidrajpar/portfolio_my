---
const base = import.meta.env.BASE_URL;
const risks = [
  { category: 'Strategic & Growth', level: 'Moderate to High', color: 'bg-orange-500', width: '75%' },
  { category: 'Operational & Food Safety', level: 'Very Low', color: 'bg-emerald-500', width: '10%' },
  { category: 'Brand & Reputational', level: 'Low', color: 'bg-emerald-400', width: '25%' },
  { category: 'Regulatory & Compliance', level: 'Very Low', color: 'bg-emerald-500', width: '5%' },
  { category: 'Financial & Capital', level: 'Moderate', color: 'bg-blue-500', width: '50%' },
  { category: 'Technology & Data', level: 'Low', color: 'bg-emerald-400', width: '25%' },
  { category: 'Workforce & Labor', level: 'Very Low', color: 'bg-emerald-500', width: '15%' },
  { category: 'Supply Chain', level: 'Low to Moderate', color: 'bg-blue-400', width: '40%' },
  { category: 'Customer Experience', level: 'Low', color: 'bg-emerald-400', width: '25%' },
];
---

<div class="bg-slate-900 p-8 lg:p-12 border border-white/10 shadow-2xl overflow-hidden relative group my-16" data-reveal>
  <!-- Subtle Grid Pattern -->
  <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.1) 1px, transparent 0); background-size: 24px 24px;"></div>

  <div class="relative z-10">
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center mb-12 gap-6">
      <div>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-orange-500 mb-2 block">Featured Framework</span>
        <h2 class="text-3xl font-black text-white leading-tight">Risk Appetite Summary.</h2>
        <p class="text-slate-400 text-xs mt-2 font-bold uppercase tracking-wider">Strategic Guardrails for High-Growth IPO Readiness</p>
      </div>
      <div class="flex gap-4">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
          <span class="text-[8px] font-bold text-slate-500 uppercase tracking-widest">Prudence</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full bg-orange-500"></div>
          <span class="text-[8px] font-bold text-slate-500 uppercase tracking-widest">Ambition</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-8">
      {risks.map((risk) => (
        <div class="group/item">
          <div class="flex justify-between items-end mb-2">
            <span class="text-[10px] font-black text-white uppercase tracking-wider">{risk.category}</span>
            <span class="text-[9px] font-bold text-slate-500 uppercase tracking-widest">{risk.level}</span>
          </div>
          <div class="h-1.5 w-full bg-white/5 overflow-hidden">
            <div
              class={`h-full ${risk.color} transition-all duration-1000 group-hover:brightness-125`}
              style={`width: ${risk.width}`}
            ></div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-6">
      <p class="text-slate-500 text-[10px] font-medium leading-relaxed max-w-md">
        This matrix visualizes the balance between <span class="text-white font-bold italic">Operational Zero-Tolerance</span> and <span class="text-white font-bold italic">Strategic Market Capture</span>. High appetite for growth requires equally robust guardrails for safety and compliance.
      </p>
      <a
        href={`${base}downloads/Risk_Appetite_Policy_Template.docx`}
        download
        class="px-6 py-3 bg-white text-slate-900 text-[10px] font-black uppercase tracking-[0.2em] hover:bg-orange-500 hover:text-white transition-all duration-300"
      >
        Download Full Policy
      </a>
    </div>
  </div>
</div>
