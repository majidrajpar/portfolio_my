---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="stat-plinth px-5 pb-6 pt-5">
  <div class="text-3xl font-black leading-none text-[#181511]">{value}</div>
  <div class="mt-3 text-[10px] font-black uppercase tracking-[0.24em] leading-snug text-[color:var(--text-secondary)]">{label}</div>
</div>
