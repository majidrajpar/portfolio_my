---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeverityClassifier from '../../components/SeverityClassifier.jsx';
---

<BaseLayout
  title="Audit Finding Severity Classifier | Majid Mumtaz"
  description="A free, browser-based tool for internal auditors to score findings across four risk factors and generate an IIA-aligned severity rating with report-ready language."
>

  <!-- Hero -->
  <section class="pt-32 pb-20 bg-[#001F5B]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-white/60 mb-6 block">Audit Intelligence Tool</span>
        <h1 class="text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
          Finding Severity Classifier.
        </h1>
        <p class="text-xl text-white/70 leading-relaxed max-w-2xl">
          Score any audit finding across four risk factors and instantly generate an IIA-aligned severity rating with report-ready language — all in your browser.
        </p>
      </div>
    </div>
  </section>

  <!-- Tool -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="mb-12" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#001F5B] mb-4 block">Step-by-Step</span>
        <h2 class="text-3xl font-black text-slate-900 mb-3">Select the four risk factors.</h2>
        <p class="text-slate-500 text-sm max-w-xl">
          Choose the option that best reflects your finding across each of the four factors. The classifier analyses the combination and determines the severity rating.
        </p>
      </div>

      <SeverityClassifier client:load />
    </div>
  </section>

  <!-- Methodology -->
  <section class="py-20 bg-slate-50 border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#001F5B] mb-4 block">Methodology</span>
        <h2 class="text-3xl font-black text-slate-900 mb-4">How ratings are determined.</h2>
        <p class="text-slate-600 text-sm leading-relaxed mb-4">
          The classifier uses a model trained on expert-labelled combinations of the four risk factors, consistent with IIA Standards and GCC audit committee expectations. It weighs factors and their interactions — not just a simple sum — to produce the severity rating.
        </p>
        <p class="text-slate-500 text-xs leading-relaxed mb-10">
          Financial exposure is assessed relative to the entity's own materiality threshold — not against absolute figures. An AED 500K exposure is immaterial for a billion-dirham group and critical for an SME. Apply your own materiality judgement when selecting this factor.
        </p>

        <!-- Severity legend -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
          <div class="bg-white border border-slate-200 border-t-2 border-t-green-500 p-5">
            <div class="text-green-600 font-black text-xs uppercase tracking-widest mb-2">Low</div>
            <div class="text-slate-600 text-xs leading-snug">Monitor and track. Follow up in next audit cycle.</div>
          </div>
          <div class="bg-white border border-slate-200 border-t-2 border-t-amber-500 p-5">
            <div class="text-amber-600 font-black text-xs uppercase tracking-widest mb-2">Medium</div>
            <div class="text-slate-600 text-xs leading-snug">Remediation plan with agreed timelines required.</div>
          </div>
          <div class="bg-white border border-slate-200 border-t-2 border-t-orange-500 p-5">
            <div class="text-orange-600 font-black text-xs uppercase tracking-widest mb-2">High</div>
            <div class="text-slate-600 text-xs leading-snug">Prompt escalation to senior management. Root cause analysis mandatory.</div>
          </div>
          <div class="bg-white border border-slate-200 border-t-2 border-t-red-700 p-5">
            <div class="text-red-700 font-black text-xs uppercase tracking-widest mb-2">Critical</div>
            <div class="text-slate-600 text-xs leading-snug">Immediate Board / Audit Committee notification required.</div>
          </div>
        </div>

        <!-- Factor table -->
        <div class="border border-slate-200 overflow-hidden">
          <table class="w-full text-xs">
            <thead>
              <tr class="bg-[#001F5B] text-white">
                <th class="text-left px-5 py-3 font-black uppercase tracking-widest text-[10px]">Factor</th>
                <th class="text-left px-5 py-3 font-black uppercase tracking-widest text-[10px]">Lower risk</th>
                <th class="text-left px-5 py-3 font-black uppercase tracking-widest text-[10px]">Moderate risk</th>
                <th class="text-left px-5 py-3 font-black uppercase tracking-widest text-[10px]">Higher risk</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {[
                ['Financial Exposure', 'Immaterial', 'Potentially material', 'Material'],
                ['Likelihood', 'Rare / isolated', 'Possible / occasional', 'Likely / recurring'],
                ['Detection', 'Easy — controls catch it', 'Moderate', 'Hard — likely undetected'],
                ['Scope', 'Single transaction', 'Single department', 'Entity-wide'],
              ].map(([factor, s1, s2, s3]) => (
                <tr class="bg-white hover:bg-slate-50 transition-colors">
                  <td class="px-5 py-3.5 font-black text-slate-900">{factor}</td>
                  <td class="px-5 py-3.5 text-slate-600">{s1}</td>
                  <td class="px-5 py-3.5 text-slate-600">{s2}</td>
                  <td class="px-5 py-3.5 text-slate-600">{s3}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
