---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuditChecklist from '../../components/AuditChecklist.jsx';
---

<BaseLayout
  title="Audit Checklist Generator | Majid Mumtaz"
  description="Generate tailored checklists for financial, compliance, operational, IT, or fraud audits. Track completion in real time and export for workpaper documentation."
>

  <!-- Hero -->
  <section class="pt-32 pb-20 bg-[#001F5B]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-white/60 mb-6 block">Audit Intelligence</span>
        <h1 class="text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
          Audit Checklist Generator.
        </h1>
        <p class="text-xl text-white/70 leading-relaxed max-w-2xl">
          Select your audit type and receive a professionally structured checklist — financial, compliance, operational, IT/ITGC, or fraud. Check off items, add custom steps, and copy a completed checklist for your workpapers.
        </p>
      </div>
    </div>
  </section>

  <!-- Tool -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="mb-12" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#001F5B] mb-4 block">Step-by-Step Checklist</span>
        <h2 class="text-3xl font-black text-slate-900 mb-3">Select your audit type to begin.</h2>
        <p class="text-slate-500 text-sm max-w-2xl">
          Each template is drawn from professional audit practice across GCC engagements. Add custom items specific to your engagement and copy the completed checklist for workpaper documentation.
        </p>
      </div>

      <AuditChecklist client:load />
    </div>
  </section>

  <!-- Methodology -->
  <section class="py-20 bg-slate-50 border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#001F5B] mb-4 block">About the Templates</span>
        <h2 class="text-3xl font-black text-slate-900 mb-4">What's included in each checklist.</h2>
        <p class="text-slate-600 text-sm leading-relaxed mb-8">
          Each template is grounded in IIA Standards, COSO Internal Control Framework, and real-world GCC audit practice. They are starting points — not exhaustive programmes. Add, remove, and adapt items to fit your engagement scope, client context, and risk profile.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
          {[
            { type: 'Financial Audit', items: 18, focus: 'IFRS compliance, balance sheet testing, journal entries, payroll, related-party transactions, management representations.' },
            { type: 'Compliance Audit', items: 16, focus: 'Licensing, regulatory filings, PDPL/GDPR, AML, health & safety, whistleblowing, DoA, mandatory training.' },
            { type: 'Operational Audit', items: 17, focus: 'Process flows, procurement, three-way matching, inventory, cash handling, KPIs, management reporting accuracy.' },
            { type: 'IT / ITGC Audit', items: 16, focus: 'Access management, change control, backup & recovery, patch management, encryption, audit logs, physical security.' },
            { type: 'Fraud Audit', items: 15, focus: "Benford's Law, vendor master, ghost employees, management override, split POs, related-party vendors, refund analysis." },
          ].map(({ type, items, focus }) => (
            <div class="bg-white border border-slate-200 border-t-2 border-t-[#001F5B] p-5">
              <div class="flex items-center justify-between mb-2">
                <div class="text-[#001F5B] font-black text-xs uppercase tracking-widest">{type}</div>
                <div class="text-[10px] font-bold text-slate-400">{items} items</div>
              </div>
              <div class="text-slate-600 text-xs leading-relaxed">{focus}</div>
            </div>
          ))}
        </div>

        <!-- Privacy -->
        <div class="bg-white border border-slate-200 px-6 py-5 flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#001F5B] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          <div>
            <div class="text-[10px] font-black uppercase tracking-widest text-[#001F5B] mb-1">Privacy &amp; Confidentiality</div>
            <p class="text-xs text-slate-600 leading-relaxed">
              This tool operates entirely within your browser. No checklist content, completion status, or custom items are transmitted to any server or stored in any database.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
