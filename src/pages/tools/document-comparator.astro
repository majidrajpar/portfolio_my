---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocumentComparator from '../../components/DocumentComparator.jsx';
import NetworkCanvas from '../../components/NetworkCanvas';

const title = "Document Version Comparator | Majid Mumtaz";
const description = "Compare two document versions side-by-side. Supports PDF, DOCX, Excel, and TXT. Highlights additions, deletions, and modifications with audit-focused classification tags.";
---

<BaseLayout title={title} description={description}>
  <section class="pt-32 pb-20 bg-[#001F5B] relative overflow-hidden">
    <NetworkCanvas client:load nodeCount={35} />
    <div class="max-w-7xl mx-auto px-8 relative z-10">
      <div class="max-w-3xl">
        <div class="text-[10px] font-black uppercase tracking-[0.4em] text-white/60 mb-4">
          Audit Intelligence
        </div>
        <h1 class="text-5xl font-black text-white tracking-tight mb-8">
          Document Version <span class="text-[#C9A84C]">Comparator</span>.
        </h1>
        <p class="text-lg text-white/70 leading-relaxed mb-10">
          Upload two versions of any policy, contract, or report and instantly see every change.
          Audit-focused classification flags <span class="font-bold text-white">control weakening</span>,
          threshold shifts, scope changes, and responsibility reassignments.
          Supports PDF (with OCR fallback), Word, Excel, and plain text.
          <span class="font-bold text-white">Everything runs in your browser — no data is uploaded.</span>
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-8">
      <div class="bg-white shadow-2xl shadow-slate-200/50">
        <DocumentComparator client:load />
      </div>
    </div>
  </section>
</BaseLayout>
