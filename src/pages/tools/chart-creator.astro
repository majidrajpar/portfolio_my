---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChartCreator from '../../components/ChartCreator.jsx';
---

<BaseLayout
  title="Chart & Infographic Creator | Majid Mumtaz"
  description="Design professional bar, line, pie, and radar charts for audit reports and governance presentations. Live preview, colour themes, no design skills required."
>

  <!-- Hero -->
  <section class="pt-32 pb-20 bg-[#001F5B]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-white/60 mb-6 block">Reporting</span>
        <h1 class="text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
          Chart & Infographic Creator.
        </h1>
        <p class="text-xl text-white/70 leading-relaxed max-w-2xl">
          Build professional charts for audit reports and governance presentations — bar, line, pie, and radar — with a live preview and colour themes designed for boardroom use. No design tools required.
        </p>
      </div>
    </div>
  </section>

  <!-- Tool -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="mb-12" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#001F5B] mb-4 block">Live Chart Builder</span>
        <h2 class="text-3xl font-black text-slate-900 mb-3">Select a chart type and enter your data.</h2>
        <p class="text-slate-500 text-sm max-w-2xl">
          Enter labels and values, choose a colour theme, and watch your chart build in real time. Copy the formatted data table for inclusion in audit reports or board packs.
        </p>
      </div>

      <ChartCreator client:load />
    </div>
  </section>

  <!-- Methodology -->
  <section class="py-20 bg-slate-50 border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#001F5B] mb-4 block">Chart Guide</span>
        <h2 class="text-3xl font-black text-slate-900 mb-4">Choosing the right chart type.</h2>
        <p class="text-slate-600 text-sm leading-relaxed mb-8">
          Chart selection affects how clearly your data communicates to a board or audit committee audience. Use this guide to match your data story to the right visual format.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
          {[
            { type: 'Bar Chart', best: 'Comparing discrete categories — audit finding counts by department, compliance scores by location, spend by vendor.', avoid: 'Time series with many data points or showing proportions of a whole.' },
            { type: 'Line Chart', best: 'Showing trends over time — monthly fraud incidents, quarterly control failures, year-on-year KPI movement.', avoid: 'Comparing unrelated categories or showing composition.' },
            { type: 'Pie / Donut Chart', best: 'Showing composition — finding distribution by severity, budget allocation by department, risk by category.', avoid: 'More than 6 segments or when precise comparison between segments matters.' },
            { type: 'Radar Chart', best: 'Comparing performance across multiple dimensions simultaneously — COSO component scores, governance domain ratings, maturity levels.', avoid: 'Audiences unfamiliar with radar charts or when precise values need to be read off axes.' },
          ].map(({ type, best, avoid }) => (
            <div class="bg-white border border-slate-200 border-t-2 border-t-[#001F5B] p-5">
              <div class="text-[#001F5B] font-black text-xs uppercase tracking-widest mb-3">{type}</div>
              <div class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Best for</div>
              <p class="text-slate-600 text-xs leading-relaxed mb-3">{best}</p>
              <div class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Avoid when</div>
              <p class="text-slate-500 text-xs leading-relaxed">{avoid}</p>
            </div>
          ))}
        </div>

        <!-- Privacy -->
        <div class="bg-white border border-slate-200 px-6 py-5 flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#001F5B] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          <div>
            <div class="text-[10px] font-black uppercase tracking-widest text-[#001F5B] mb-1">Privacy &amp; Confidentiality</div>
            <p class="text-xs text-slate-600 leading-relaxed">
              This tool operates entirely within your browser. No data labels, values, or chart outputs are transmitted to any server or stored in any database.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
