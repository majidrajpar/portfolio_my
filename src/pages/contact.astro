---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm';
import NetworkCanvas from '../components/NetworkCanvas';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contact | Majid Mumtaz — CIA, ACA, FCCA"
  description="Discuss consulting engagements, interim CAE mandates, board advisory, or IPO readiness. Available globally."
>
  <section class="relative overflow-hidden px-4 pt-24 md:px-8 md:pt-28">
    <div class="editorial-panel relative mx-auto max-w-7xl overflow-hidden px-6 py-10 md:px-10 md:py-12">
      <NetworkCanvas client:load nodeCount={35} />
      <div class="relative z-10 max-w-4xl" data-reveal>
        <span class="hero-chip mb-8">Contact</span>
        <h1 class="headline-display max-w-4xl text-[clamp(3rem,7vw,6rem)] font-black text-white">
          Start the
          <span class="block text-[#f4c98b]">conversation</span>
          <span class="block">with intent.</span>
        </h1>
        <p class="mt-8 max-w-3xl text-base leading-8 text-white/74 md:text-[1.1rem] md:leading-9">
          Full-time Director of Internal Audit and CAE roles globally. Interim mandates, board advisory, IPO readiness, and high-stakes risk architecture also considered.
        </p>
      </div>
    </div>
  </section>

  <section class="px-4 py-4 pb-10 md:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-6 lg:grid-cols-[0.86fr_1.14fr]">
        <div class="soft-shell px-7 py-10 md:px-10 md:py-12" data-reveal>
          <span class="eyebrow-label">Direct Contact</span>
          <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-[#181511]">Contact details.</h2>
          <div class="luxury-divider mt-7 max-w-sm"></div>

          <div class="mt-8 space-y-6">
            <div class="stat-plinth p-6">
              <div class="meta-label text-[#a33a21]">Email</div>
              <a href="mailto:majidrajpar@gmail.com" class="mt-3 block text-lg font-semibold text-[#1d3557]">majidrajpar@gmail.com</a>
            </div>
            <div class="stat-plinth p-6">
              <div class="meta-label text-[#a33a21]">Location</div>
              <div class="mt-3 text-lg font-semibold text-[#181511]">Dubai, United Arab Emirates</div>
              <div class="mt-2 text-sm leading-7 text-[color:var(--text-secondary)]">Golden Visa Holder</div>
            </div>
            <div class="stat-plinth p-6">
              <div class="meta-label text-[#a33a21]">Links</div>
              <div class="mt-3 space-y-3 text-sm font-semibold">
                <a href="https://www.linkedin.com/in/majid-m-4b097118/" target="_blank" rel="noopener noreferrer" class="block text-[#1d3557]">LinkedIn ↗</a>
                <a href="https://veritux.com/consultants/majid-mumtaz/" target="_blank" rel="noopener noreferrer" class="block text-[#1d3557]">Veritux ↗</a>
                <a href="https://app.gocatalant.com/c/_/profile/kd6vrg/verify/" target="_blank" rel="noopener noreferrer" class="block text-[#1d3557]">Catalant ↗</a>
                <a href="https://wa.me/971507471708" target="_blank" rel="noopener noreferrer" class="block text-[#1d3557]">WhatsApp ↗</a>
              </div>
            </div>
          </div>

          <div class="quote-panel mt-8 p-7">
            <div class="meta-label text-[#1d3557]">Availability</div>
            <p class="mt-4 text-lg leading-8 text-[#1b1a17]">
              Open to full-time Director of Internal Audit and CAE roles globally, alongside selective interim mandates and board advisory.
            </p>
            <div class="mt-6">
              <a href={`${base}cv/Majid-Mumtaz-Internal-Audit-Director-CV.pdf`} class="btn-secondary" download>Download CV</a>
            </div>
          </div>
        </div>

        <div class="editorial-panel px-7 py-10 md:px-10 md:py-12" data-reveal data-reveal-delay="1">
          <div class="meta-label text-[#f4c98b]">Send a Message</div>
          <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-white">Bring a real problem.</h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-white/68">
            If the organization has outgrown sample-based comfort, compliance-first reporting, or cosmetic independence, this is the place to start.
          </p>
          <div class="h-px max-w-sm bg-gradient-to-r from-[#c7964c]/60 to-transparent mt-8 mb-8"></div>
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
