---
import BaseLayout from '../layouts/BaseLayout.astro';
import MetricCard from '../components/MetricCard.astro';
import CareerTimeline from '../components/CareerTimeline.jsx';
import NetworkCanvas from '../components/NetworkCanvas';
import { getCareerMilestones } from '../lib/db.js';

const careerData = getCareerMilestones();
const base = import.meta.env.BASE_URL;

const books = [
  { title: 'Handbook of Risk Red Flags in Restaurants', desc: "A practitioner's guide to preventing failure through early detection of risk indicators.", url: 'https://www.amazon.com/dp/B0GDTBRZPM', cover: `${base}images/books/risk-red-flags.jpg` },
  { title: 'The Un-Financial Risk Manager', desc: 'Protecting value in the real world — ESG, cyber, and emerging strategic risks.', url: 'https://www.amazon.com/dp/B0GDMW53GG', cover: `${base}images/books/unfinancial-risk-manager.jpg` },
  { title: '10 Forensic Accounting Skills', desc: 'Practical handbook on fraud detection, forensic investigation, and evidence management.', url: 'https://www.amazon.com/dp/B0G7T4X3RT', cover: `${base}images/books/forensic-accounting-skills.jpg` },
  { title: 'ITGC Program Guide', desc: 'A strategic approach to IT General Controls — security, compliance, and enterprise value protection.', url: 'https://www.amazon.com/dp/B0FCG96QS8', cover: `${base}images/books/itgc-program-guide.jpg` },
  { title: 'Internal Audit Guide for Dine-In Locations in the Middle East', desc: 'Comprehensive audit guide for restaurant operations in the GCC region.', url: 'https://www.amazon.com/dp/B0DY2NRPQ9', cover: `${base}images/books/internal-audit-dinein.jpg` },
];

const metrics = [
  { value: 'AED 7.7M', label: 'Total Financial Impact — Fraud Detection' },
  { value: '$127M', label: 'M&A Due Diligence — Workstream Lead' },
  { value: '78%', label: 'Reduction in Fraud Incidents' },
  { value: '20+', label: 'Years Leadership' },
  { value: '100%', label: 'Population Testing — 7 Critical Domains' },
  { value: '2', label: 'Listing Readiness Programmes Delivered' },
];
---

<BaseLayout
  title="About | Majid Mumtaz — Chief Audit Executive"
  description="20+ years finding the operational and governance gaps that cost businesses money — fraud detection, board-grade assurance, controls that close the risk they were built for. CIA, ACA, FCCA. Big 4 trained. Open to full-time roles globally."
>
  <section class="relative overflow-hidden px-4 pt-24 md:px-8 md:pt-28">
    <div class="editorial-panel relative mx-auto max-w-7xl overflow-hidden px-6 py-10 md:px-10 md:py-12">
      <NetworkCanvas client:load nodeCount={35} />
      <div class="relative z-10 grid gap-8 lg:grid-cols-[1fr_0.52fr] lg:items-end" data-reveal>
        <div>
          <span class="hero-chip mb-8">Leadership Profile</span>
          <h1 class="headline-display max-w-4xl text-[clamp(3rem,7vw,6.4rem)] font-black text-white">
            Twenty years.
            <span class="block text-[#f4c98b]">One mission.</span>
            <span class="block">Protect the capital.</span>
          </h1>
          <p class="mt-8 max-w-3xl text-base leading-8 text-white/74 md:text-[1.15rem] md:leading-9">
            Director of Internal Audit and board-facing advisor. Big 4 trained. Triple-certified. Published across external audit, governance, and compliance outlets. Built for organizations that need assurance with real operating weight.
          </p>
          <div class="luxury-divider mt-10 mb-8 max-w-lg"></div>
          <div class="flex flex-wrap gap-3">
            {['CIA', 'ACA', 'FCCA', 'Big 4 — EY & KPMG', 'Published · 6 Articles', '20+ Years'].map((badge) => (
              <span class="hero-chip">{badge}</span>
            ))}
          </div>
        </div>
        <div class="hidden lg:block">
          <div class="overflow-hidden rounded-[28px] border border-white/12">
            <img
              src={`${base}images/majid-profile.jpg`}
              alt="Majid Mumtaz"
              class="h-[420px] w-full object-cover object-top"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-5 md:px-8">
    <div class="mx-auto grid max-w-7xl gap-4 md:grid-cols-6">
      {metrics.map((m, i) => (
        <div data-reveal data-reveal-delay={String((i % 3) + 1)}>
          <MetricCard value={m.value} label={m.label} />
        </div>
      ))}
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
        <div class="editorial-panel overflow-hidden px-7 py-8 md:px-8 md:py-10" data-reveal>
          <div class="meta-label text-[#f4c98b]">Biography</div>
          <div class="mt-6 overflow-hidden rounded-[28px] border border-white/12">
            <img src={`${base}images/majid-profile.jpg`} alt="Majid Mumtaz" class="h-[520px] w-full object-cover" loading="lazy" />
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="https://www.linkedin.com/in/majid-m-4b097118/" target="_blank" rel="noopener noreferrer" class="btn-secondary-light">LinkedIn</a>
            <a href="https://www.linkedin.com/newsletters/7339153291630510080/" target="_blank" rel="noopener noreferrer" class="btn-secondary-light">Newsletter</a>
            <a href="https://www.youtube.com/@AuditBitz" target="_blank" rel="noopener noreferrer" class="btn-secondary-light">AuditBitz</a>
          </div>
        </div>

        <div class="soft-shell px-7 py-10 md:px-10 md:py-12" data-reveal data-reveal-delay="1">
          <span class="eyebrow-label">Biography</span>
          <h2 class="mt-4 text-[clamp(2.1rem,4.8vw,4rem)] leading-[1.02] text-[#181511]">Built to turn assurance into an executive instrument.</h2>
          <div class="luxury-divider mt-7 max-w-md"></div>
          <div class="mt-8 space-y-6 text-[color:var(--text-secondary)]">
            <p class="body-luxe">
              I build audit functions that protect capital. Over 20 years, I have designed and led internal audit departments from inception, embedding governance structures, control frameworks, and technology platforms that give boards credible assurance.
            </p>
            <p class="body-luxe">
              My work spans three connected domains: <strong class="text-[#181511]">IA function building</strong>, <strong class="text-[#181511]">forensic analytics and fraud detection</strong>, and <strong class="text-[#181511]">board assurance and IPO readiness</strong> across DFM, Tadawul, and Nomu-oriented programs.
            </p>
            <p class="body-luxe">
              Big 4 trained through Ernst & Young and KPMG, I combine technical rigor with executive communication, translating complex findings into board-level decisions rather than compliance paperwork.
            </p>
            <p class="body-luxe">
              Currently delivering governance, risk, and internal audit advisory through <a href="https://veritux.com/consultants/majid-mumtaz/" target="_blank" rel="noopener noreferrer" class="text-[#a33a21] font-semibold hover:underline">Veritux</a> in Dubai — real estate developers, family offices, and pre-IPO businesses — and through <a href="https://app.gocatalant.com/c/_/profile/kd6vrg/verify/" target="_blank" rel="noopener noreferrer" class="text-[#a33a21] font-semibold hover:underline">Catalant</a> for project-based mandates with global organisations. Open to full-time Director of Internal Audit and CAE roles globally.
            </p>
          </div>

          <div class="mt-10 grid gap-4 md:grid-cols-3">
            <div class="stat-plinth p-6">
              <div class="meta-label text-[#a33a21]">Credentials</div>
              <div class="mt-4 space-y-2 text-sm font-semibold text-[#181511]">
                <div>CIA</div>
                <div>ACA</div>
                <div>FCCA</div>
                <div>COSO ERM Certified</div>
              </div>
            </div>
            <div class="stat-plinth p-6">
              <div class="meta-label text-[#a33a21]">Background</div>
              <div class="mt-4 space-y-2 text-sm font-semibold text-[#181511]">
                <div>Ernst & Young</div>
                <div>KPMG</div>
                <div>Al Faisaliah Group</div>
                <div>Kitopi</div>
                <div>Veritux</div>
              </div>
            </div>
            <div class="stat-plinth p-6">
              <div class="meta-label text-[#a33a21]">Leadership</div>
              <div class="mt-4 space-y-2 text-sm font-semibold text-[#181511]">
                <div>Board & AC Reporting</div>
                <div>Three Lines of Defence</div>
                <div>Risk Appetite Frameworks</div>
                <div>Multi-Jurisdiction Programmes</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="soft-shell mx-auto max-w-7xl px-7 py-10 md:px-10 md:py-12">
      <div class="mb-10" data-reveal>
        <span class="eyebrow-label">Professional Trajectory</span>
        <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-[#181511]">Strategic career architecture.</h2>
        <p class="body-luxe mt-5 max-w-3xl">A 20-year progression from Big 4 operational roots to group-level profit protection, transformation, and board advisory.</p>
      </div>
      <div class="relative group" data-reveal data-reveal-delay="1">
        <div class="overflow-x-auto pb-6 -mx-7 px-7 md:-mx-10 md:px-10">
          <div class="min-w-[800px] lg:min-w-0 editorial-panel border border-white/10 shadow-2xl">
            <CareerTimeline client:visible careerData={careerData} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10" data-reveal>
        <span class="eyebrow-label">Core Practice Areas</span>
        <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-[#181511]">Signature capabilities.</h2>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {[
          ['IA Function Building', 'Designing and building internal audit departments from the ground up — charter, methodology, risk-based audit plans, team structure, and IIA Standards alignment.'],
          ['Forensic Analytics & Fraud Detection', 'ML-powered continuous monitoring, population testing, anomaly detection, and pattern recognition deployed where manual comfort is no longer defensible.'],
          ['Board Assurance & IPO Readiness', 'ICOFR implementation, COSO ERM frameworks, and regulatory readiness structured for boards, regulators, and investors.'],
        ].map(([title, desc], i) => (
          <div class="glass-card rounded-[30px] p-8" data-reveal data-reveal-delay={String(i + 1)}>
            <div class="meta-label text-[#a33a21]">0{i + 1}</div>
            <h3 class="mt-4 text-xl leading-tight text-[#181511]">{title}</h3>
            <p class="mt-4 text-sm leading-8 text-[color:var(--text-secondary)]">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="soft-shell mx-auto max-w-7xl px-7 py-10 md:px-10 md:py-12">
      <div class="mb-8" data-reveal>
        <span class="eyebrow-label">Skills & Credentials</span>
        <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-[#181511]">Continuing education and technical skills.</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { institution: 'Harvard Business School Online', program: 'Disruptive Strategy', area: 'Strategy' },
          { institution: 'COSO', program: 'ERM Framework Certification', area: 'Risk Management' },
          { institution: 'HKUST', program: 'Blockchain & Financial Innovation', area: 'Technology' },
          { institution: 'IBM', program: 'AI Governance & Ethics', area: 'Governance' },
          { institution: 'West Virginia University', program: 'Fraud Investigation Techniques', area: 'Forensics' },
          { institution: 'NYIF', program: 'Financial Modeling & Valuation', area: 'Finance' },
        ].map((item, i) => (
          <div class="glass-card rounded-[28px] p-6" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <div class="meta-label text-[#a33a21]">{item.area}</div>
            <h3 class="mt-3 text-base leading-tight font-bold text-[#181511]">{item.program}</h3>
            <p class="mt-2 text-sm text-[color:var(--text-secondary)]">{item.institution}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8" id="books">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10" data-reveal>
        <span class="eyebrow-label">Published Works</span>
        <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-[#181511]">Books and frameworks.</h2>
        <p class="body-luxe mt-5 max-w-3xl">Writing that extends the same operating thesis into internal audit, risk management, and forensic accounting.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {books.map((book, i) => (
          <a href={book.url} target="_blank" rel="noopener noreferrer" class="glass-card flex gap-5 rounded-[30px] p-6" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <div class="w-24 flex-shrink-0 overflow-hidden rounded-[18px] bg-slate-100 aspect-[2/3]">
              <img src={book.cover} alt={book.title} class="h-full w-full object-cover" loading="lazy" />
            </div>
            <div class="flex min-w-0 flex-1 flex-col">
              <div class="meta-label text-[#a33a21]">Amazon</div>
              <h3 class="mt-3 text-lg leading-tight text-[#181511]">{book.title}</h3>
              <p class="mt-3 text-sm leading-7 text-[color:var(--text-secondary)]">{book.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
