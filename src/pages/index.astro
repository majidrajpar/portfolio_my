---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm';
import NetworkCanvas from '../components/NetworkCanvas';
import GrammarBackground from '../components/GrammarBackground';
import { getCaseStudies } from '../lib/db.js';

const featuredProjects = getCaseStudies().slice(0, 3);
const base = import.meta.env.BASE_URL;

const signals = [
  {
    title: 'Governance That Survives Pressure',
    body: 'Audit structures designed to hold when growth, incentives, regulatory friction, and operator shortcuts start bending the business out of shape.',
  },
  {
    title: 'Commercially Literate Assurance',
    body: 'Functions repositioned from compliance overhead into instruments for revenue protection, exposure detection, and board-grade decision support.',
  },
  {
    title: 'Population-Based Risk Detection',
    body: 'Full-population testing and exception design used where static controls and sample-based comfort are no longer defensible.',
  },
];

const impactChips = [
  'Pre-IPO governance',
  'Board-grade reporting',
  'Fraud analytics',
  'ICOFR and SOX design',
  'ERM architecture',
  'Audit transformation',
];

const proofMetrics = [
  { value: '20+', label: 'Years of audit, risk, and governance leadership' },
  { value: 'AED 7.7M', label: 'financial impact recovered or protected' },
  { value: '47% → 3%', label: 'false positives reduced in fraud detection logic' },
  { value: '7', label: 'countries across GCC and adjacent markets' },
];

const publications = [
  {
    outlet: 'IIA Internal Auditor',
    date: 'February 2026',
    title: 'Teaching an Algorithm to Filter False Flags',
    summary: 'A practitioner account of reducing false positives while making fraud logic trustworthy enough for operations teams to use.',
    href: 'https://internalauditor.theiia.org/en/voices/2026/february/teaching-an-algorithm-to-filter-false-flags/',
  },
  {
    outlet: 'GRC Report',
    date: 'April 2026',
    title: 'AI Authorization Is Not AI Accountability',
    summary: 'Boards may approve AI, but accountability for what those systems decide in production is still structurally missing.',
    href: 'https://www.grcreport.com/post/ai-authorization-is-not-ai-accountability',
  },
  {
    outlet: 'Corporate Compliance Insights',
    date: 'April 2026',
    title: 'FCPA Compliance Programs Are Missing Important Nuances About How Bribery Works in the Persian Gulf',
    summary: 'A challenge to imported compliance frameworks that miss how relationship-based bribery risk actually operates in the Gulf.',
    href: 'https://www.corporatecomplianceinsights.com/fcpa-compliance-programs-missing-nuances-bribery-persian-gulf/',
  },
];

const testimonials = [
  {
    photo: `${base}images/testimonials/sally.png`,
    quote: 'Majid brings credibility, integrity, and a genuine collaborative mindset to internal audit, and any organisation would benefit greatly from his leadership and expertise.',
    name: 'Sally Swanepoel',
    role: 'VP Finance, Kitopi',
  },
  {
    photo: `${base}images/testimonials/steve.png`,
    quote: 'His intuitive approach allowed an efficient and speedy, yet thoughtful improvement of systems and culture. I can highly recommend him in future Internal Audit or Executive Leadership roles.',
    name: 'Steve Skoien',
    role: 'Restaurant Executive, ALFA',
  },
  {
    photo: `${base}images/testimonials/alkadi.png`,
    quote: 'He demonstrates superior technical Internal Audit & Risk ability and consistently produces work of exceptional quality.',
    name: 'Abdulaziz AlKadi',
    role: 'CHRO and Board Member',
  },
];
---

<BaseLayout
  title="Majid Mumtaz | Director of Internal Audit — CIA, ACA, FCCA"
  description="Director of Internal Audit with 20+ years finding the operational and governance gaps businesses have not priced yet — fraud detection, board-grade assurance, and controls that actually close the risk they were built for."
>
  <section class="relative overflow-hidden px-4 pt-24 md:px-8 md:pt-28">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute left-[6%] top-[10%] h-48 w-48 rounded-full bg-[#c7964c]/20 blur-3xl"></div>
      <div class="absolute right-[8%] top-[12%] h-56 w-56 rounded-full bg-[#a33a21]/18 blur-3xl"></div>
    </div>

    <div class="editorial-panel relative mx-auto max-w-7xl overflow-hidden px-6 py-8 md:px-10 md:py-10">
      <NetworkCanvas client:load nodeCount={42} />

      <div class="relative z-10 grid gap-8 lg:grid-cols-[1.5fr_0.82fr] lg:items-start">
        <div class="pt-4" data-reveal>
          <span class="hero-chip mb-8">Director of Internal Audit | CIA · ACA · FCCA</span>
          <h1 class="headline-display max-w-4xl text-[clamp(3.1rem,8vw,7.1rem)] font-black text-white">
            Audit leadership
            <span class="block text-[#f4c98b]">for when capital</span>
            <span class="block">is actually at risk.</span>
          </h1>
          <p class="mt-8 max-w-3xl text-base leading-8 text-white/74 md:text-[1.15rem] md:leading-9">
            Boards pay for assurance. Most receive compliance theatre. Twenty years closing that gap: governance that survives scrutiny, fraud detection that tests the full population, and reporting built around the risks the business still has not priced.
          </p>

          <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:flex-wrap">
            <a href="#case-studies" class="btn-primary">See the Work</a>
            <a href={`${base}contact/`} class="btn-secondary-light">Get in Touch</a>
          </div>

          <div class="luxury-divider mt-10 mb-7"></div>

          <div class="grid gap-3 sm:grid-cols-3">
            <div class="frame-panel px-4 py-4">
              <div class="meta-label text-white/45">Current Focus</div>
              <div class="mt-2 text-sm font-bold leading-6 text-white/85">Director of Internal Audit and CAE roles globally, plus selective advisory mandates.</div>
            </div>
            <div class="frame-panel px-4 py-4">
              <div class="meta-label text-white/45">Markets</div>
              <div class="mt-2 text-sm font-bold leading-6 text-white/85">UAE, KSA, Qatar, Pakistan, and cross-border GCC operations.</div>
            </div>
            <div class="frame-panel px-4 py-4">
              <div class="meta-label text-white/45">Operating Model</div>
              <div class="mt-2 text-sm font-bold leading-6 text-white/85">Business-first audit, structural independence, population testing, board-grade reporting.</div>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-4" data-reveal data-reveal-delay="2">
          <!-- Profile card -->
          <div class="frame-panel overflow-hidden p-0">
            <div class="relative">
              <img
                src={`${base}images/majid-profile-home.jpg`}
                alt="Majid Mumtaz — Director of Internal Audit"
                class="h-[300px] w-full object-cover object-top"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 px-5 py-4">
                <div class="text-base font-black text-white">Majid Mumtaz</div>
                <div class="mt-1 text-[9px] font-black uppercase tracking-[0.26em] text-white/60">CIA · ACA · FCCA · Big 4 Trained</div>
              </div>
            </div>
          </div>

          <!-- Signal Board — 2×2 grid -->
          <div class="frame-panel p-5 md:p-6">
            <div class="flex items-center justify-between gap-4 mb-4">
              <div class="meta-label text-[#f4c98b]">Signal Board</div>
              <div class="h-px flex-1 bg-gradient-to-r from-[#c7964c]/50 to-transparent"></div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              {proofMetrics.map((metric) => (
                <div class="rounded-[20px] border border-white/10 bg-black/10 px-4 py-3">
                  <div class="text-2xl font-black tracking-tight text-white">{metric.value}</div>
                  <div class="mt-1.5 text-[9px] uppercase tracking-[0.18em] text-white/50 leading-4">{metric.label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-5 md:px-8">
    <div class="mx-auto grid max-w-7xl gap-3 md:grid-cols-6">
      {impactChips.map((chip, i) => (
        <div class="impact-chip" data-reveal data-reveal-delay={String((i % 3) + 1)}>{chip}</div>
      ))}
    </div>
  </section>

  <section class="px-4 pb-4 md:px-8">
    <div class="mx-auto max-w-7xl" data-reveal>
      <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="soft-shell p-7 md:p-10">
          <span class="eyebrow-label">Positioning</span>
          <h2 class="mt-4 max-w-2xl text-[clamp(2.1rem,5vw,4.2rem)] leading-[1.01] text-[#181511]">
            Protecting capital by redesigning how assurance is built, measured, and trusted.
          </h2>
          <div class="luxury-divider mt-8 max-w-md"></div>
          <p class="body-luxe mt-8 max-w-3xl">
            The strongest audit functions do not merely confirm process compliance. They create visibility where the organisation has already become too complex for intuition, too fast for manual oversight, and too exposed for sample-based reassurance.
          </p>
        </div>

        <div class="quote-panel p-7 md:p-10">
          <div class="meta-label text-[#1d3557]">Operating Thesis</div>
          <p class="mt-6 font-serif text-[clamp(1.4rem,2vw,2.1rem)] leading-[1.7] text-[#1b1a17]">
            Assurance should feel like strategic clarity, not procedural noise.
          </p>
          <p class="mt-6 text-sm leading-8 text-[color:var(--text-secondary)]">
            That means structural independence, commercial context, full-population logic, and reporting that changes board behaviour rather than satisfying reporting rituals.
          </p>
        </div>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {signals.map((signal, i) => (
          <article class="glass-card rounded-[30px] p-7" data-reveal data-reveal-delay={String(i + 1)}>
            <div class="meta-label text-[#a33a21]">0{i + 1}</div>
            <h3 class="mt-4 text-xl leading-tight text-[#181511]">{signal.title}</h3>
            <p class="mt-4 text-sm leading-8 text-[color:var(--text-secondary)]">{signal.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="mx-auto max-w-7xl" data-reveal>
      <div class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr]">
        <div class="editorial-panel px-7 py-10 md:px-8 md:py-12">
          <div class="relative z-10 flex h-full flex-col justify-between">
            <div>
              <div class="meta-label text-[#f4c98b]">Published In</div>
              <div class="mt-6 space-y-3">
                {[
                  { outlet: 'IIA Internal Auditor', date: 'Feb 2026' },
                  { outlet: 'ACCA AB Magazine', date: 'May 2026' },
                  { outlet: 'GRC Report', date: 'Apr 2026' },
                  { outlet: 'Corporate Compliance Insights', date: 'Apr 2026' },
                  { outlet: 'Consultancy ME', date: 'Apr 2026' },
                ].map(({ outlet, date }) => (
                  <div class="flex items-center justify-between gap-4 border-b border-white/8 pb-3">
                    <span class="text-sm font-bold text-white/88">{outlet}</span>
                    <span class="text-[9px] font-black uppercase tracking-[0.2em] text-white/36 shrink-0">{date}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="mt-10">
              <a href={`${base}about/#books`} class="text-[10px] font-black uppercase tracking-[0.22em] text-white/40 hover:text-white/70 transition-colors">Published Books ↗</a>
            </div>
          </div>
        </div>

        <div class="soft-shell px-7 py-10 md:px-10 md:py-12">
          <span class="eyebrow-label">About</span>
          <h2 class="mt-4 text-[clamp(2rem,5vw,3.9rem)] leading-[1.03] text-[#181511]">
            Twenty years inside complex operating environments.
          </h2>
          <div class="luxury-divider mt-7 max-w-md"></div>
          <p class="body-luxe mt-6 max-w-4xl">
            Twenty years inside complex audit environments: multi-brand F&amp;B platforms spanning seven countries, healthcare subsidiaries targeting Nomu listing, and holding groups restructuring for a new governance era. The assumption that sampling equals coverage is how fraud compounds unseen. A 5% sample carries roughly a 40% chance of missing a fraud cluster. Not a methodology. A liability transfer.
          </p>
          <p class="mt-6 max-w-4xl text-lg leading-9 text-[#1d3557]">
            The AED 7.7M recovered existed in the 95% that sampling would have missed. Where most programmes wait for the loss to surface, the work here builds detection before the pattern repeats.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href={`${base}about/`} class="btn-secondary">Full Profile</a>
            <a href={`${base}cv/Majid-Mumtaz-Internal-Audit-Director-CV.pdf`} class="btn-primary" download>Download CV</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="case-studies" class="px-4 py-4 md:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
        <div class="max-w-3xl" data-reveal>
          <span class="eyebrow-label">Transformation Archive</span>
          <h2 class="mt-4 text-[clamp(2.1rem,5vw,4.4rem)] leading-[1.02] text-[#181511]">Client outcomes with operating weight.</h2>
        </div>
        <p class="max-w-lg text-base leading-8 text-[color:var(--text-secondary)]" data-reveal data-reveal-delay="1">
          Every engagement begins with the business problem. Controls, analytics, and reporting are designed around the commercial reality instead of retrofitted after the fact.
        </p>
      </div>

      <div class="luxury-divider mt-8"></div>

      <div class="mt-10 grid gap-5 lg:grid-cols-[1.08fr_0.92fr_0.92fr]">
        {featuredProjects.map((project, i) => (
          <a
            href={`${base}projects/${project.slug}/`}
            class={`group glass-card flex h-full flex-col rounded-[32px] p-8 ${i === 0 ? 'lg:min-h-[420px]' : ''}`}
            data-reveal
            data-reveal-delay={String((i % 3) + 1)}
          >
            <div class="flex items-center justify-between gap-3">
              <span class="rounded-full bg-[#1d3557]/8 px-3 py-1 text-[10px] font-black uppercase tracking-[0.25em] text-[#1d3557]">
                {project.categories?.[0] ?? project.category}
              </span>
              {project.duration && (
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">{project.duration}</span>
              )}
            </div>
            <h3 class="mt-6 text-xl leading-tight text-[#181511] transition-colors group-hover:text-[#a33a21]">
              {project.title}
            </h3>
            {project.impact && (
              <p class="mt-5 border-l-2 border-[#a33a21]/25 pl-4 text-sm leading-7 text-[color:var(--text-secondary)]">
                {project.impact}
              </p>
            )}
            <div class="mt-8 pt-5 text-[10px] font-black uppercase tracking-[0.3em] text-[#1d3557]">
              View Details
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 flex justify-center">
        <a href={`${base}projects/`} class="btn-primary">View Key Projects</a>
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="editorial-panel mx-auto max-w-7xl px-6 py-10 md:px-10" data-reveal>
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="flex flex-col justify-center">
          <span class="meta-label text-[#f4c98b]">Approach</span>
          <h2 class="mt-4 text-[clamp(2.1rem,5vw,4rem)] leading-[1.02] text-white">How the work is designed.</h2>
          <div class="h-px max-w-sm bg-gradient-to-r from-[#c7964c]/60 to-transparent mt-6"></div>
          <p class="mt-6 text-sm leading-7 text-white/60 max-w-xs">Each engagement follows the same sequence — commercial context first, structural independence second, population logic third.</p>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {[
            ['01', 'Business First', 'Two weeks inside the commercial reality before opinion. The control environment is treated as a symptom, not the root issue.'],
            ['02', 'Structural Independence', 'Audit charter, committee access, and reporting design are set before fieldwork. Independence is structural, not cosmetic.'],
            ['03', 'Population Testing', 'Where others sample, the full population is tested. The economics of missing the pattern are too large for inherited comfort.'],
            ['04', 'Board-Grade Reporting', 'Findings are framed for the decision each board member needs to make, not as a status update disguised as reporting.'],
          ].map(([step, title, desc], i) => (
            <div class="frame-panel p-6" data-reveal data-reveal-delay={String((i % 2) + 1)}>
              <div class="meta-label text-[#f4c98b]">{step}</div>
              <h3 class="mt-4 text-lg text-white">{title}</h3>
              <p class="mt-3 text-sm leading-7 text-white/68">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div data-reveal>
          <span class="eyebrow-label">External Publications</span>
          <h2 class="mt-4 text-[clamp(2rem,5vw,4rem)] leading-[1.02] text-[#181511]">Arguments built for public scrutiny.</h2>
          <p class="body-luxe mt-5 max-w-2xl">
            Governance, AI accountability, fraud detection logic, and regional compliance frameworks argued in public rather than hidden inside internal decks.
          </p>
          <div class="quote-panel mt-8 p-7">
            <div class="meta-label text-[#1d3557]">Editorial Thesis</div>
            <p class="mt-4 text-xl leading-9 text-[#1b1a17]">
              The point is not to prove that a control exists. The point is to prove whether it still works when incentives, complexity, and operating pressure start distorting the organization.
            </p>
          </div>

          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <div class="stat-plinth p-6">
              <div class="meta-label text-[#a33a21]">Public Positioning</div>
              <div class="mt-3 text-3xl font-black text-[#181511]">5+</div>
              <div class="mt-2 text-sm leading-7 text-[color:var(--text-secondary)]">external outlets spanning audit, compliance, governance, and algorithmic risk.</div>
            </div>
            <div class="stat-plinth p-6">
              <div class="meta-label text-[#a33a21]">Recurring Theme</div>
              <div class="mt-3 text-3xl font-black text-[#181511]">Structure</div>
              <div class="mt-2 text-sm leading-7 text-[color:var(--text-secondary)]">Most failures described as design failures, not isolated control misses.</div>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          {publications.map((publication, i) => (
            <a
              href={publication.href}
              target="_blank"
              rel="noopener noreferrer"
              class="glass-card block rounded-[28px] p-7"
              data-reveal
              data-reveal-delay={String(i + 1)}
            >
              <div class="flex flex-wrap items-center gap-3">
                <span class="rounded-full bg-[#a33a21]/8 px-3 py-1 text-[10px] font-black uppercase tracking-[0.24em] text-[#a33a21]">{publication.outlet}</span>
                <span class="meta-label text-slate-400">{publication.date}</span>
              </div>
              <h3 class="mt-5 text-xl leading-tight text-[#181511]">{publication.title}</h3>
              <p class="mt-4 text-sm leading-7 text-[color:var(--text-secondary)]">{publication.summary}</p>
              <div class="mt-5 text-[10px] font-black uppercase tracking-[0.3em] text-[#1d3557]">Read Article</div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8" data-reveal>
        <span class="eyebrow-label">Recommendations</span>
        <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-[#181511]">What colleagues say when the work is done well.</h2>
      </div>
      <div class="grid gap-5 lg:grid-cols-[1.12fr_0.94fr_0.94fr]">
      {testimonials.map((testimonial, i) => (
        <div class="glass-card rounded-[30px] p-8" data-reveal data-reveal-delay={String(i + 1)}>
          <div class="text-5xl leading-none text-[#a33a21]/20">"</div>
          <p class="mt-5 text-sm leading-8 text-[color:var(--text-secondary)]">{testimonial.quote}</p>
          <div class="mt-8 flex items-center gap-4 border-t border-[color:var(--line-soft)] pt-5">
            <img src={testimonial.photo} alt={testimonial.name} class="h-14 w-14 rounded-full object-cover ring-2 ring-[#1d3557]/8" />
            <div>
              <div class="text-sm font-black text-[#181511]">{testimonial.name}</div>
              <div class="text-[11px] font-bold uppercase tracking-[0.15em] text-slate-400">{testimonial.role}</div>
            </div>
          </div>
        </div>
      ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-4 pb-10 md:px-8">
    <div class="editorial-panel mx-auto max-w-7xl overflow-hidden px-6 py-10 md:px-10 md:py-12">
      <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div data-reveal>
          <span class="meta-label text-[#f4c98b]">Contact</span>
          <h2 class="mt-4 text-[clamp(2.2rem,5vw,4rem)] leading-[1.02] text-white">Bring the audit function closer to the actual risk.</h2>
          <p class="mt-6 max-w-xl text-base leading-8 text-white/70">
            If the board is getting status updates instead of governance instruments, or the assurance model still assumes sampling is enough, that is the gap this work is built to close.
          </p>
          <div class="h-px max-w-sm bg-gradient-to-r from-[#c7964c]/60 to-transparent mt-8"></div>
          <div class="mt-8 space-y-4">
            <a href="mailto:majidrajpar@gmail.com" class="block text-sm font-black text-white/88">majidrajpar@gmail.com</a>
            <a href="https://www.linkedin.com/in/majid-m-4b097118/" target="_blank" rel="noopener noreferrer" class="block text-sm font-black text-white/88">LinkedIn Profile</a>
            <a href="https://veritux.com/consultants/majid-mumtaz/" target="_blank" rel="noopener noreferrer" class="block text-sm font-black text-white/88">Veritux Consultant Page</a>
            <a href="https://app.gocatalant.com/c/_/profile/kd6vrg/verify/" target="_blank" rel="noopener noreferrer" class="block text-sm font-black text-white/88">Catalant Expert Profile</a>
            <a href="https://wa.me/971507471708" target="_blank" rel="noopener noreferrer" class="block text-sm font-black text-white/88">WhatsApp</a>
          </div>
        </div>
        <div data-reveal data-reveal-delay="2">
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
