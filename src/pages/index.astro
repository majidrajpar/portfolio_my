---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm';
import NetworkCanvas from '../components/NetworkCanvas';
import GrammarBackground from '../components/GrammarBackground';
import { getCaseStudies } from '../lib/db.js';

const featuredProjects = getCaseStudies().slice(0, 3);

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Majid Mumtaz | Director of Internal Audit — CIA, ACA, FCCA"
  description="Director of Internal Audit with 20+ years finding the operational and governance gaps businesses haven't priced yet — fraud detection, board-grade assurance, and controls that actually close the risk they were built for. CIA, ACA, FCCA. Based in Dubai, open to full-time roles globally."
>

  <!-- Hero -->
  <section class="min-h-screen flex items-center justify-center pt-20 overflow-hidden relative bg-[#001F5B]">
    <NetworkCanvas client:load nodeCount={42} />
    <div class="max-w-6xl mx-auto px-8 z-10 flex flex-col items-center text-center" data-reveal>
      <span class="inline-block px-6 py-2 mb-10 bg-white/10 border border-white/30 text-white rounded text-[10px] font-black uppercase tracking-[0.4em]">
        Director of Internal Audit &nbsp;|&nbsp; CIA · ACA · FCCA
      </span>
      <h1 class="text-[clamp(3rem,9vw,6.5rem)] text-center leading-[0.93] mb-10 tracking-tight text-white font-black">
        I Build Audit Functions<br />That Actually Protect<br />Capital.
      </h1>
      <p class="text-lg md:text-xl mb-14 text-blue-100 font-medium max-w-3xl leading-relaxed">
        Boards pay for audit assurance. Most receive compliance theatre. The gap between stated coverage and actual protection is structural: it persists because it is invisible from inside the function producing it. Twenty years closing that gap: governance frameworks that hold under external scrutiny, fraud detection that tests the full population instead of the 5% that misses most of it, and board reporting built around the operational risk the board has not yet priced. Open to full-time Director of Internal Audit and CAE roles globally.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <a href="#case-studies" class="btn-primary">See the Work ↓</a>
        <a href={`${base}contact/`} class="btn-secondary-light">Get in Touch →</a>
      </div>
    </div>
  </section>

  <!-- Client Logo Strip -->
  <section class="bg-[#001F5B] py-12 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-8" data-reveal>
      <p class="text-[10px] font-black uppercase tracking-[0.4em] text-white/60 text-center mb-10">Organisations I've Served</p>
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-14 opacity-60 grayscale hover:grayscale-0 transition-all duration-700">
        {[
          'EY',
          'KPMG',
          'Kitopi',
          "McDonald's",
          'Al Faisaliah Group',
          'BMA Asset Management',
          'Veritux',
          'Umbrex',
        ].map((org) => (
          <div class="h-7 md:h-9 flex items-center justify-center">
            <span class="text-white font-black text-[10px] md:text-xs uppercase tracking-[0.3em]">{org}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Published Author Strip -->
  <section class="bg-[#001F5B] py-3.5 border-t border-[#C9A84C]/20">
    <div class="max-w-7xl mx-auto px-8">
      <a href={`${base}about/#books`} class="flex flex-wrap items-center justify-center gap-2 md:gap-5 group">
        <svg class="w-4 h-4 text-[#C9A84C] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <span class="text-[#C9A84C] font-black text-[10px] uppercase tracking-[0.35em]">Published Author</span>
        <span class="text-white/20 hidden md:inline">&middot;</span>
        <span class="text-white/60 text-[11px] font-medium">5 Books on Amazon — Internal Audit, Risk Management & Forensic Accounting</span>
        <span class="text-white/20 hidden md:inline">&middot;</span>
        <span class="text-[#C9A84C] text-[10px] font-black uppercase tracking-[0.3em] group-hover:text-white transition-colors">View Books ↗</span>
      </a>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="py-4 bg-slate-100 relative overflow-hidden">
    <GrammarBackground client:visible variant="stats" />
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px">
        {[
          { value: '20+', label: 'Years Experience', sub: 'GCC, MENA & emerging markets' },
          { value: '7', label: 'Countries', sub: 'Cross-border audit coverage' },
          { value: '5', label: 'Published Pieces', sub: 'IIA, GRC Report (x2), Consultancy ME, CCI' },
          { value: 'AED 7.7M', label: 'Total Financial Impact', sub: 'Fraud detected & losses prevented' },
        ].map((s) => (
          <div class="bg-white text-center px-6 py-8">
            <div class="text-3xl font-black text-[#001F5B] mb-1">{s.value}</div>
            <div class="text-[10px] font-black uppercase tracking-widest text-slate-700 mb-0.5">{s.label}</div>
            <div class="text-[10px] text-slate-400">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[200px_1fr] gap-16 items-start max-w-6xl mx-auto" data-reveal>
        <div class="flex justify-center lg:justify-start lg:pt-2">
          <div class="relative w-48 h-48 overflow-hidden border border-slate-300 shadow-xl flex-shrink-0">
            <img src={`${base}images/majid-profile-home.jpg`} alt="Majid Mumtaz" class="w-full h-full object-cover object-top" />
          </div>
        </div>
        <div>
          <span class="text-[10px] font-black uppercase tracking-[0.4em] text-[#001F5B] mb-4 block">About</span>
          <h2 class="text-[clamp(2rem,5vw,3.5rem)] text-slate-900 mb-8 leading-tight font-black tracking-tighter">
            Twenty Years. One Focus:<br /><span class="text-[#001F5B]">Protecting Capital.</span>
          </h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Twenty years inside complex audit environments: multi-brand F&amp;B platforms spanning 7 countries, healthcare subsidiaries targeting Nomu listing, and holding groups restructuring for a new governance era. The assumption that sampling equals coverage is how fraud compounds unseen. A 5% sample carries roughly a 40% chance of missing a fraud cluster. Not a methodology. A liability transfer. The AED 7.7M we recovered existed in the 95% that sampling would have missed. Where most programmes waited for the loss to surface, we built detection before the pattern repeated.
          </p>
          <p class="text-[#001F5B] text-base font-bold italic leading-relaxed mb-10">
            Now seeking a full-time Director of Internal Audit or CAE role with organisations ready to make that same shift.
          </p>
          <a href={`${base}about/`} class="btn-secondary">Full Profile & Credentials</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Case Studies -->
  <section id="case-studies" class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-10">
        <div class="max-w-2xl" data-reveal>
          <span class="text-[10px] font-black uppercase tracking-[0.4em] text-[#001F5B] mb-6 block">Transformation Archive</span>
          <h2 class="text-[clamp(2.5rem,6vw,4.5rem)] text-slate-900 mb-0 font-black tracking-tighter">Client Outcomes.</h2>
        </div>
        <p class="text-slate-600 text-lg max-w-md leading-relaxed text-right" data-reveal>
          Every engagement starts with the business problem. The technology follows.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
        {featuredProjects.map((project, i) => (
          <a
            href={`${base}projects/${project.slug}/`}
            class="group border border-slate-200 bg-white p-6 flex flex-col gap-4 hover:border-[#001F5B]/40 hover:shadow-sm transition-all duration-200"
            data-reveal
            data-reveal-delay={String((i % 3) + 1)}
          >
            <div class="flex items-center justify-between gap-3">
              <span class="text-[9px] font-black uppercase tracking-[0.25em] bg-[#001F5B]/8 text-[#001F5B] px-3 py-1 border border-[#001F5B]/15">
                {project.categories?.[0] ?? project.category}
              </span>
              {project.duration && (
                <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest flex-shrink-0">
                  {project.duration}
                </span>
              )}
            </div>
            <h3 class="text-sm font-black text-slate-900 leading-snug group-hover:text-[#001F5B] transition-colors">
              {project.title}
            </h3>
            {project.impact && (
              <p class="text-[11px] text-slate-500 leading-relaxed border-l-2 border-[#001F5B]/30 pl-3">
                {project.impact}
              </p>
            )}
            <span class="text-[9px] font-black uppercase tracking-[0.25em] text-[#001F5B] mt-auto group-hover:text-blue-700 transition-colors">
              View Details →
            </span>
          </a>
        ))}
      </div>

      <div class="flex justify-center">
        <a href={`${base}projects/`} class="group flex items-center gap-4 text-slate-900 font-black tracking-[0.4em] uppercase text-xs hover:text-[#001F5B] transition-all border-b border-slate-300 pb-4">
          View Key Projects
          <span>→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- How I Work -->
  <section class="py-24 bg-[#001F5B] relative overflow-hidden">
    <GrammarBackground client:visible variant="dark-grid" />
    <div class="max-w-7xl mx-auto px-8">
      <div class="text-center mb-16" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-white/50 mb-6 block">Approach</span>
        <h2 class="text-[clamp(2.5rem,6vw,4rem)] text-white font-black tracking-tighter">How I Work.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-0">
        {[
          {
            step: '01',
            title: 'Business First',
            desc: 'Two weeks inside the commercial reality before forming audit opinion. The control environment is a symptom — I trace it to the business pressure that created it.',
          },
          {
            step: '02',
            title: 'Structural Independence',
            desc: 'Audit charter, reporting line, and committee access established before fieldwork begins. Independence is a structural condition, not a professional posture.',
          },
          {
            step: '03',
            title: '100% Population Testing',
            desc: 'Where most teams sample, I test the full population. The AED 7.7M we recovered existed in the 95% sampling would have missed. Analytics makes this scalable.',
          },
          {
            step: '04',
            title: 'Board-Grade Reporting',
            desc: 'Findings framed for the decision each committee member needs to make — not a status update, but a governance instrument built to survive external scrutiny.',
          },
        ].map((item, i) => (
          <div class={`relative p-8${i > 0 ? ' md:border-l md:border-white/10' : ''}`} data-reveal data-reveal-delay={String(i + 1)}>
            <div class="w-10 h-10 flex items-center justify-center bg-white/10 font-black text-white text-sm mb-6">{item.step}</div>
            <h4 class="text-white font-black text-base mb-3">{item.title}</h4>
            <p class="text-white/60 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-14" data-reveal>
        <a href={`${base}contact/`} class="btn-secondary-light">Get in Touch →</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-8">
      <div class="text-center mb-20" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-[#001F5B] mb-6 block">LinkedIn Recommendations</span>
        <h2 class="text-[clamp(2.5rem,6vw,4.5rem)] text-slate-900 font-black tracking-tighter">What Colleagues Say.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {[
          {
            photo: `${base}images/testimonials/sally.png`,
            quote: 'Majid brings credibility, integrity, and a genuine collaborative mindset to internal audit, and any organisation — particularly within the F&B or consumer space — would benefit greatly from his leadership and expertise. I would recommend him without hesitation.',
            name: 'Sally Swanepoel',
            role: 'VP Finance',
            org: 'Kitopi',
            context: 'Senior Leadership',
          },
          {
            photo: `${base}images/testimonials/steve.png`,
            quote: 'Majid was, indeed, a pleasure to work alongside. His intuitive approach allowed an efficient and speedy, yet thoughtful improvement of ALFA\'s systems and culture. I can highly recommend Majid Mumtaz in future endeavors of Internal Audit or Executive Leadership.',
            name: 'Steve Skoien',
            role: 'Restaurant Executive',
            org: 'ALFA · Al Faisaliah Group',
            context: 'Direct Management',
          },
          {
            photo: `${base}images/testimonials/alkadi.png`,
            quote: 'He demonstrates superior technical Internal Audit & Risk ability and produces work of exceptional quality. Majid always committed to producing work that meets high standards.',
            name: 'Abdulaziz AlKadi',
            role: 'CHRO · Board Member',
            org: 'Al Faisaliah Group',
            context: 'Board Assurance',
          },
          {
            photo: `${base}images/testimonials/osama.png`,
            quote: 'His partnerships with the business and functional leaders was based on trust, integrity, and deep respect for his knowledge of the Alfa environment, people, and processes. He brought a hands-on approach to not only identifying risks but also how to best mitigate those risks, in a consultative manner.',
            name: 'Osama Abu Baker',
            role: 'Supply Chain Director',
            org: 'Alfa co. · Al Faisaliah Group',
            context: 'Cross-functional Partnership',
          },
          {
            photo: `${base}images/testimonials/lane.png`,
            quote: 'He has the strongest skills of any internal auditor that I have had the privilege of working with. He is methodical in his approach, yet intuitive in following the clues. He has made our organization stronger and safer because of his diligence and powerful skill set.',
            name: 'Lane Cardwell',
            role: 'President',
            org: 'Cardwell Hospitality Advisory',
            context: 'Direct Management',
          },
          {
            photo: `${base}images/testimonials/leslie.png`,
            quote: 'A trusted friend, colleague and confidant, Majid can be relied upon to do the right thing. His personable persona and good humour has often defused any number of potentially explosive situations, making him an asset irreplaceable in any audit or senior management team.',
            name: 'Leslie D. Bailey',
            role: 'Managing Director',
            org: 'ALFA · Al Faisaliah Group',
            context: 'Senior Leadership',
          },
        ].map((t, i) => (
          <div class="glass-card p-10 flex flex-col" data-reveal data-reveal-delay={String(i + 1)}>
            <div class="text-[#001F5B]/20 text-7xl font-black leading-none mb-4 select-none">"</div>
            <p class="text-slate-700 text-[13px] leading-relaxed flex-1 mb-10 italic font-medium">{t.quote}</p>
            <div class="pt-6 border-t border-slate-200">
              <div class="flex items-center gap-4 mb-3">
                <img 
                  src={t.photo} 
                  alt={t.name} 
                  class="w-14 h-14 rounded-full object-cover aspect-square flex-shrink-0 ring-2 ring-[#001F5B]/10" 
                />
                <div class="flex-1">
                  <div class="text-slate-900 font-black text-sm leading-tight">{t.name}</div>
                  <div class="text-slate-500 text-[11px] font-bold mt-0.5 leading-tight">{t.role}</div>
                  <div class="text-[#001F5B] text-[10px] font-black uppercase tracking-wider mt-1">{t.org}</div>
                </div>
              </div>
              <div class="text-slate-400 text-[9px] font-black uppercase tracking-widest mt-2">{t.context}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="flex justify-center mt-16">
        <a href="https://www.linkedin.com/in/majid-m-4b097118/" target="_blank" rel="noopener noreferrer" class="btn-secondary inline-flex items-center gap-3">
          View All Recommendations on LinkedIn →
        </a>
      </div>
    </div>
  </section>

  <!-- External Publications -->
  <section class="py-24 bg-[#001F5B] relative overflow-hidden">
    <GrammarBackground client:visible variant="dark-grid" />
    <div class="max-w-7xl mx-auto px-8 relative z-10">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-8">
        <div data-reveal>
          <span class="text-[10px] font-black uppercase tracking-[0.4em] text-white/50 mb-6 block">Published Work</span>
          <h2 class="text-[clamp(2rem,5vw,3.5rem)] text-white font-black tracking-tighter">External Publications.</h2>
        </div>
      </div>

      <!-- Primary: IIA -->
      <a
        href="https://internalauditor.theiia.org/en/voices/2026/february/teaching-an-algorithm-to-filter-false-flags/"
        target="_blank"
        rel="noopener noreferrer"
        class="block border border-white/20 bg-white/5 p-10 md:p-16 hover:bg-white/10 transition-all duration-500 group mb-4"
        data-reveal
      >
        <div class="flex flex-col md:flex-row gap-12 items-start">
          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="text-[10px] font-black uppercase tracking-wider px-3 py-1.5 bg-white text-[#001F5B]">IIA &mdash; Internal Auditor Magazine</span>
              <span class="text-[10px] font-black uppercase tracking-wider text-white/50">February 2026</span>
            </div>
            <p class="text-[#C9A84C]/80 text-[10px] font-bold uppercase tracking-widest mb-8">Voices Column — selected practitioners only</p>
            <h3 class="text-[clamp(1.5rem,3vw,2.25rem)] text-white font-black leading-tight mb-6 group-hover:text-blue-200 transition-colors">
              Teaching an Algorithm to Filter False Flags
            </h3>
            <p class="text-white/70 text-base leading-relaxed mb-10 max-w-2xl">
              How iterative refinement of anomaly-detection logic, through close collaboration with operations teams, reduced false positives from 47% to 3% at a cloud kitchen operator. A practitioner's account of building ML fraud detection that earns trust across the business.
            </p>
            <span class="inline-flex items-center gap-2 text-white font-black text-[10px] uppercase tracking-[0.3em] border-b border-white/30 pb-1 group-hover:border-white transition-colors">
              Read on IIA.org &nbsp;&rarr;
            </span>
          </div>
          <div class="md:w-40 flex-shrink-0 flex flex-col items-center text-center pt-2">
            <div class="border border-[#C9A84C]/30 bg-[#C9A84C]/5 px-8 py-6 flex flex-col items-center group-hover:border-[#C9A84C]/50 transition-colors">
              <div class="text-[#C9A84C] font-black text-4xl leading-none tracking-tighter">47%</div>
              <div class="text-white/40 text-lg font-black my-1">↓</div>
              <div class="text-[#C9A84C] font-black text-4xl leading-none tracking-tighter mb-4">3%</div>
              <div class="text-white/50 text-[9px] font-black uppercase tracking-widest leading-snug text-center">False Positive<br/>Reduction</div>
            </div>
          </div>
        </div>
      </a>

      <!-- Secondary: GRC Report -->
      <a
        href="https://www.grcreport.com/post/ai-authorization-is-not-ai-accountability"
        target="_blank"
        rel="noopener noreferrer"
        class="block border border-white/20 bg-white/5 p-10 hover:bg-white/10 transition-all duration-500 group mb-4"
        data-reveal
      >
        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="text-[10px] font-black uppercase tracking-wider px-3 py-1.5 bg-white text-[#001F5B]">GRC Report</span>
              <span class="text-[10px] font-black uppercase tracking-wider text-white/50">April 2026</span>
            </div>
            <h3 class="text-[clamp(1.2rem,2.5vw,1.75rem)] text-white font-black leading-tight mb-4 group-hover:text-blue-200 transition-colors">
              AI Authorization Is Not AI Accountability
            </h3>
            <p class="text-white/70 text-sm leading-relaxed mb-8 max-w-2xl">
              Boards are approving AI authorization policies, but the accountability architecture for what those systems decide in production has not been built. The gap sits between sign-off and consequence.
            </p>
            <span class="inline-flex items-center gap-2 text-white font-black text-[10px] uppercase tracking-[0.3em] border-b border-white/30 pb-1 group-hover:border-white transition-colors">
              Read on GRC Report &nbsp;&rarr;
            </span>
          </div>
          <div class="md:w-40 flex-shrink-0 flex flex-col items-center text-center pt-2">
            <div class="border border-[#C9A84C]/30 bg-[#C9A84C]/5 px-8 py-6 flex flex-col items-center group-hover:border-[#C9A84C]/50 transition-colors">
              <div class="text-[#C9A84C] font-black text-3xl leading-none tracking-tighter mb-3">AED 7.7M</div>
              <div class="text-white/50 text-[9px] font-black uppercase tracking-widest leading-snug text-center">Missed by sampling<br/>Found by population<br/>testing</div>
            </div>
          </div>
        </div>
      </a>

      <!-- Tertiary: GRC Report #2 -->
      <a
        href="https://www.grcreport.com/post/the-cfo-is-the-audit-independence-risk-youre-not-managing"
        target="_blank"
        rel="noopener noreferrer"
        class="block border border-white/20 bg-white/5 p-10 hover:bg-white/10 transition-all duration-500 group mb-4"
        data-reveal
      >
        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="flex-1">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="text-[10px] font-black uppercase tracking-wider px-3 py-1.5 bg-white text-[#001F5B]">GRC Report</span>
              <span class="text-[10px] font-black uppercase tracking-wider text-white/50">March 2026</span>
            </div>
            <h3 class="text-[clamp(1.2rem,2.5vw,1.75rem)] text-white font-black leading-tight mb-4 group-hover:text-blue-200 transition-colors">
              The CFO Is the Audit Independence Risk You're Not Managing
            </h3>
            <p class="text-white/70 text-sm leading-relaxed mb-8 max-w-2xl">
              Budget control, functional reporting, and remuneration authority sit with the CFO in most organisations. Each is an independence risk. None appear on the audit committee's agenda. The gap is structural, not interpersonal.
            </p>
            <span class="inline-flex items-center gap-2 text-white font-black text-[10px] uppercase tracking-[0.3em] border-b border-white/30 pb-1 group-hover:border-white transition-colors">
              Read on GRC Report &nbsp;&rarr;
            </span>
          </div>
          <div class="md:w-40 flex-shrink-0 flex flex-col items-center text-center pt-2">
            <div class="border border-[#C9A84C]/30 bg-[#C9A84C]/5 px-8 py-6 flex flex-col items-center group-hover:border-[#C9A84C]/50 transition-colors">
              <div class="text-[#C9A84C] font-black text-3xl leading-none tracking-tighter mb-3">3</div>
              <div class="text-white/50 text-[9px] font-black uppercase tracking-widest leading-snug text-center">Independence<br/>Vectors the AC<br/>Isn't Watching</div>
            </div>
          </div>
        </div>
      </a>

      <!-- Tertiary: Consultancy ME -->
      <a
        href="https://www.consultancy-me.com/news/12980/the-risk-of-algorithmic-entropy-when-ai-models-age-faster-than-evolving-fraud"
        target="_blank"
        rel="noopener noreferrer"
