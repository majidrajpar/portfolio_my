---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NetworkCanvas from '../../../components/NetworkCanvas';
import GrammarBackground from '../../../components/GrammarBackground';
import { getCaseStudies, getProfessionalEngagements, getCategoryMeta } from '../../../lib/db.js';
const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  const categoryMeta = getCategoryMeta();
  const caseStudies = getCaseStudies().map(s => ({
    id: s.slug,
    title: s.title,
    description: s.subtitle,
    impact: s.impact,
    categories: s.categories,
    techStack: s.techStack,
    starr: s.starr,
  }));
  const engagements = getProfessionalEngagements().map(e => ({
    id: e.slug,
    title: e.title,
    description: e.desc,
    impact: e.outcome,
    categories: e.categories,
    techStack: [],
    starr: null,
  }));
  const allProjects = [...caseStudies, ...engagements];

  return categoryMeta.map((cat) => ({
    params: { slug: cat.slug },
    props: { cat, allProjects },
  }));
}

const { cat, allProjects } = Astro.props as { cat: any; allProjects: any[] };
const filtered = allProjects.filter(p => p.categories.includes(cat.name));
---

<BaseLayout
  title={`${cat.name} | Engagements — Majid Mumtaz`}
  description={cat.description}
>
  <section class="relative overflow-hidden px-4 pt-24 md:px-8 md:pt-28">
    <div class="editorial-panel relative mx-auto max-w-7xl overflow-hidden px-6 py-10 md:px-10 md:py-12">
      <NetworkCanvas client:load nodeCount={35} />
      <div class="relative z-10 grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end lg:gap-10">
        <div data-reveal>
          <a href={`${base}projects/`} class="mb-7 inline-flex text-[11px] font-black uppercase tracking-[0.28em] text-white/58 transition-colors hover:text-white">
            ← All Practice Areas
          </a>
          <span class="hero-chip mb-6 md:mb-7">Practice Area</span>
          <h1 class="headline-display max-w-4xl text-[clamp(3rem,6.3vw,5.5rem)] font-black text-white">
            {cat.name}
          </h1>
          <p class="mt-6 max-w-3xl text-[15px] leading-7 text-white/74 md:mt-8 md:text-[1.1rem] md:leading-9">
            {cat.description}
          </p>
        </div>
        <div class="quote-panel p-6 md:p-8" data-reveal data-reveal-delay="1">
          <span class="eyebrow-label text-[#f4c98b]/80">Coverage</span>
          <p class="mt-4 text-base leading-7 text-white/82 md:mt-5 md:text-lg md:leading-8">{filtered.length} engagement{filtered.length === 1 ? '' : 's'} mapped to this area, presented as operational outcomes rather than framework slogans.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-5 md:px-8">
    <div class="soft-shell mx-auto flex max-w-7xl items-start gap-3 px-5 py-5 md:px-7" data-reveal>
      <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-[#c7964c]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-sm leading-7 text-[color:var(--text-secondary)]">
        <span class="meta-label text-[#181511]">Confidentiality Notice</span>
        Case studies are abstracted where required to protect client and employer confidentiality while preserving the actual decision pattern and business consequence.
      </p>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between" data-reveal>
        <div>
          <span class="eyebrow-label">Mapped Engagements</span>
          <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-[#181511]">Selected mandates in {cat.name.toLowerCase()}.</h2>
        </div>
        <p class="body-luxe max-w-2xl">Each entry is framed around mandate, intervention, and commercial or governance consequence rather than generic control language.</p>
      </div>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-6 xl:grid-cols-3">
        {filtered.map((project: any, i: number) => (
          <article
            class="glass-card flex h-full flex-col rounded-[30px] p-6 text-left md:p-8"
            data-reveal
            data-reveal-delay={String((i % 3) + 1)}
          >
            <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <span class="inline-flex w-fit rounded-full bg-[#181512] px-3 py-1 text-[10px] font-black uppercase tracking-[0.2em] text-[#f4c98b]">
                {cat.name}
              </span>
              {project.duration && (
                <span class="flex flex-shrink-0 items-center gap-1 text-[10px] font-black uppercase tracking-[0.18em] text-slate-400">
                  <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  {project.duration}
                </span>
              )}
            </div>

            <h3 class="text-[1.28rem] leading-tight text-[#181511] md:text-[1.45rem]">
              {project.title}
            </h3>

            <p class="mt-4 flex-1 text-sm leading-7 text-[color:var(--text-secondary)] md:leading-8">
              {project.description}
            </p>

            {project.impact && (
              <div class="quote-panel mt-6 p-5">
                <span class="meta-label text-white/45">Impact</span>
                <p class="mt-3 text-sm leading-7 text-white/82">{project.impact}</p>
              </div>
            )}

            {project.techStack?.length > 0 && (
              <div class="mt-6 flex flex-wrap gap-2">
                {project.techStack.slice(0, 3).map((tech: string) => (
                  <span class="rounded-full border border-[color:var(--line-soft)] bg-white/75 px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.18em] text-slate-600">
                    {tech}
                  </span>
                ))}
              </div>
            )}

            <div class="mt-7 border-t border-[color:var(--line-soft)] pt-5">
              <a
                href={`${base}projects/${project.id}/`}
                class="inline-flex items-center text-[11px] font-black uppercase tracking-[0.24em] text-[#181511] transition-colors hover:text-[#8d6035]"
              >
                View Case Study
                <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
  <section class="relative overflow-hidden px-4 py-8 pb-12 md:px-8">
    <div class="editorial-panel relative mx-auto max-w-7xl overflow-hidden px-6 py-10 text-center md:px-10 md:py-14">
    <GrammarBackground client:visible variant="dark-grid" />
      <div class="relative z-10" data-reveal>
        <span class="hero-chip mb-5 md:mb-6">Discuss The Brief</span>
        <h2 class="mx-auto max-w-3xl text-[clamp(2rem,4.4vw,3.8rem)] leading-[1.03] text-white">If your challenge sits in this practice area, the next step is context, not theatre.</h2>
        <p class="mx-auto mt-5 max-w-2xl text-[15px] leading-7 text-white/72 md:mt-6 md:text-base md:leading-8">The useful conversation starts with mandate, constraint, risk posture, and stakeholder reality. Everything else follows from that.</p>
        <a href={`${base}contact/`} class="btn-primary mt-8 inline-flex">Start the Conversation</a>
      </div>
    </div>
  </section>
</BaseLayout>
