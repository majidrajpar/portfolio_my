---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects, categorySlug } from '../../data/projects.js';
const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  return projects.map((p: any) => ({
    params: { id: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props as { project: any };
const catSlug = project.categories?.[0] ? categorySlug(project.categories[0]) : 'corporate-governance';
const hasStarr = project.starr && project.starr.situation;
---

<BaseLayout
  title={`${project.title} | Majid Mumtaz`}
  description={project.description ?? project.subtitle ?? ''}
>
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-[#001F5B]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="mb-4">
        <a href={`${base}projects/`} class="text-white/60 hover:text-white text-xs font-black uppercase tracking-widest transition-colors">
          ← All Case Studies
        </a>
      </div>
      <div class="max-w-4xl" data-reveal>
        {project.categories?.[0] && (
          <span class="inline-block px-3 py-1 text-[10px] font-black uppercase tracking-[0.2em] bg-white text-[#001F5B] mb-6">
            {project.categories[0]}
          </span>
        )}
        <h1 class="text-4xl lg:text-5xl font-black text-white mb-6 leading-tight">
          {project.title}
        </h1>
        {project.impact && (
          <div class="pl-5 border-l-4 border-white/40">
            <div class="text-[10px] font-black text-white/50 uppercase tracking-widest mb-1">Impact Delivered</div>
            <div class="text-white font-bold text-lg leading-snug">{project.impact}</div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-12">

          {hasStarr ? (
            <!-- STARR Narrative -->
            <div class="space-y-10">
              {[
                { label: 'The Situation', content: project.starr.situation },
                { label: 'The Mandate', content: project.starr.task },
                { label: 'The Intervention', content: project.starr.action },
                { label: 'The Outcome', content: project.starr.result },
                { label: 'Reflection', content: project.starr.reflection },
              ].map((section, i) => (
                <div class="relative pl-10 pb-10 border-l-2 border-slate-200 last:border-transparent" data-reveal>
                  <div class="absolute left-[-11px] top-0 w-5 h-5 rounded-full bg-white border-4 border-[#001F5B] shadow-md"></div>
                  <span class="text-[11px] font-black uppercase tracking-[0.25em] text-[#C9A84C] block mb-3">{section.label}</span>
                  <p class="text-slate-700 text-base leading-relaxed">{section.content}</p>
                </div>
              ))}
            </div>
          ) : (
            <!-- Simple description for engagements -->
            <div data-reveal>
              <p class="text-slate-600 leading-relaxed text-base">{project.description}</p>
              {project.impact && (
                <div class="mt-8 pl-5 border-l-4 border-[#001F5B]">
                  <div class="text-[10px] font-black text-[#001F5B] uppercase tracking-widest mb-1">Key Outcome</div>
                  <div class="text-slate-900 font-bold text-lg leading-snug">{project.impact}</div>
                </div>
              )}
            </div>
          )}

          <!-- Data Disclaimer -->
          <div class="p-4 bg-amber-50 border border-amber-200 text-xs text-amber-800" data-reveal>
            <strong class="font-black uppercase tracking-wider">Engagement Privacy:</strong> All client names, organisational identifiers, and specific figures have been anonymised in accordance with professional standards and confidentiality obligations.
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8" data-reveal data-reveal-delay="1">

          {project.techStack && project.techStack.length > 0 && (
            <div class="bg-white border border-slate-200 p-6">
              <h3 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-4">Tech Stack / Frameworks</h3>
              <div class="flex flex-wrap gap-2">
                {project.techStack.map((tech: string) => (
                  <span class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider bg-slate-100 text-slate-700 border border-slate-200">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          )}

          {project.categories?.[0] && (
            <div class="bg-white border border-slate-200 p-6">
              <h3 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-3">Practice Area</h3>
              <span class="inline-block px-3 py-1 text-[10px] font-black uppercase tracking-[0.2em] bg-[#001F5B] text-white">
                {project.categories[0]}
              </span>
            </div>
          )}

          <!-- CTA -->
          <div class="bg-[#001F5B] p-6">
            <h3 class="text-white font-black text-sm mb-3">Discuss a Similar Engagement</h3>
            <p class="text-white/70 text-xs mb-5 leading-relaxed">Facing a similar challenge? Let's explore how this approach applies to your context.</p>
            <a href={`${base}contact/`} class="block text-center px-4 py-3 bg-white text-[#001F5B] font-black text-xs uppercase tracking-widest hover:bg-slate-100 transition-colors">
              Start the Conversation
            </a>
          </div>

          <div>
            <a
              href={`${base}projects/`}
              class="inline-flex items-center text-[#001F5B] font-black text-xs uppercase tracking-widest hover:text-blue-700 transition-colors"
            >
              ← All Case Studies
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
