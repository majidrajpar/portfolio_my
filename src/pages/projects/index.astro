---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.jsx';
import NetworkCanvas from '../../components/NetworkCanvas';
import { getCaseStudies, getProfessionalEngagements } from '../../lib/db.js';

const strategicCaseStudies = getCaseStudies();
const professionalEngagements = getProfessionalEngagements();
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Strategic Case Studies | Client Outcomes — Majid Mumtaz"
  description="High-stakes audit, risk, and governance outcomes across GCC and international operations. Structured around the business problem, not the control framework."
>
  <section class="relative overflow-hidden px-4 pt-24 md:px-8 md:pt-28">
    <div class="editorial-panel relative mx-auto max-w-7xl overflow-hidden px-6 py-10 md:px-10 md:py-12">
      <NetworkCanvas client:load nodeCount={35} />
      <div class="relative z-10 max-w-4xl" data-reveal>
        <span class="hero-chip mb-8">Executive Portfolio</span>
        <h1 class="headline-display max-w-4xl text-[clamp(3rem,7vw,6.2rem)] font-black text-white">
          Strategic
          <span class="block text-[#f4c98b]">outcomes</span>
          <span class="block">with operating weight.</span>
        </h1>
        <p class="mt-8 max-w-3xl text-base leading-8 text-white/74 md:text-[1.15rem] md:leading-9">
          High-stakes audit, risk, and governance engagements structured around the business problem, not the control framework that appears after the fact.
        </p>
      </div>
    </div>
  </section>

  <section class="px-4 py-5 md:px-8">
    <div class="soft-shell mx-auto flex max-w-7xl items-start gap-3 px-5 py-5 md:px-7" data-reveal>
      <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-[#c7964c]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
      </svg>
      <p class="text-sm leading-7 text-[color:var(--text-secondary)]">
        <span class="meta-label text-[#181511]">Engagement Privacy</span>
        Client names and proprietary identifiers are anonymised in accordance with confidentiality obligations. Figures and outcomes reflect real-world impact while protecting organizational privacy.
      </p>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10" data-reveal>
        <span class="eyebrow-label">Strategic Case Studies</span>
        <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-[#181511]">Selected mandates.</h2>
      </div>
      <div class="space-y-8">
        {strategicCaseStudies.map((study) => (
          <CaseStudyCard client:visible study={study} />
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-4 pb-8 md:px-8">
    <div class="soft-shell mx-auto max-w-7xl px-7 py-10 md:px-10 md:py-12">
      <div class="mb-10 text-center" data-reveal>
        <span class="eyebrow-label">Breadth of Experience</span>
        <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-[#181511]">Professional engagements catalog.</h2>
        <p class="body-luxe mx-auto mt-5 max-w-3xl">Additional advisory and audit mandates across the GCC and international markets, presented as a higher-level portfolio of outcomes.</p>
      </div>

      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {professionalEngagements.map((engagement, i) => (
          <div class="glass-card flex flex-col rounded-[30px] p-8" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <div class="mb-4">
              <span class="rounded-full bg-[#a33a21]/8 px-3 py-1 text-[10px] font-black uppercase tracking-[0.24em] text-[#a33a21]">{engagement.category}</span>
            </div>
            <h3 class="text-xl leading-tight text-[#181511]">{engagement.title}</h3>
            <p class="mt-4 flex-1 text-sm leading-8 text-[color:var(--text-secondary)]">{engagement.desc}</p>
            <div class="mt-6 border-t border-[color:var(--line-soft)] pt-5">
              <span class="meta-label text-slate-400">Key Outcome</span>
              <p class="mt-3 text-sm font-semibold leading-7 text-[#181511]">{engagement.outcome}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 flex justify-center">
        <a href={`${base}contact/`} class="btn-primary">Start the Conversation</a>
      </div>
    </div>
  </section>
</BaseLayout>
