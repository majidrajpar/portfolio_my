---
import BaseLayout from '../layouts/BaseLayout.astro';
import documents from '../data/documents.json';
const base = import.meta.env.BASE_URL;

const categories = ['All', ...new Set((documents as any[]).map((d: any) => d.category))];
---

<BaseLayout
  title="Resources | Professional Internal Audit Downloads — Majid Mumtaz"
  description="Professional internal audit frameworks, checklists, guides, and tools. Download risk control matrices, fraud prevention guides, SOX implementation guides, and more."
>
  <!-- Hero -->
  <section class="pt-32 pb-20 bg-[#001F5B]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="max-w-3xl" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-white/60 mb-6 block">Professional Downloads</span>
        <h1 class="text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
          Resources.
        </h1>
        <p class="text-xl text-white/70 leading-relaxed max-w-2xl">
          Complimentary frameworks, checklists, and guides for internal audit professionals. Direct, Instant Access.
        </p>
      </div>
    </div>
  </section>

  <!-- Documents Grid -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">

      <!-- Category Filters -->
      <div class="flex flex-wrap gap-2 mb-12" id="filter-bar">
        {categories.map((cat, idx) => (
          <button
            data-filter={cat}
            class={`filter-btn px-4 py-2 text-[10px] font-black uppercase tracking-widest border transition-all duration-150 ${idx === 0 ? 'bg-[#001F5B] border-[#001F5B] text-white' : 'border-slate-200 text-slate-600 bg-white hover:border-[#001F5B]/40 hover:text-slate-900'}`}
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="docs-grid">
        {(documents as any[]).map((doc: any, i: number) => (
          <div
            class="bg-white border border-slate-200 p-6 hover:shadow-md transition-shadow flex flex-col"
            data-category={doc.category}
            data-reveal
            data-reveal-delay={String((i % 3) + 1)}
          >
            <!-- Category + Meta -->
            <div class="flex items-center justify-between mb-4">
              <span class="inline-block px-2 py-1 text-[10px] font-black uppercase tracking-wider bg-[#001F5B] text-white">
                {doc.category}
              </span>
              <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">{doc.size}</span>
            </div>

            <!-- Title -->
            <h3 class="text-slate-900 font-black text-base mb-3 leading-tight flex-1">
              {doc.title}
            </h3>

            <!-- Description -->
            <p class="text-slate-500 text-xs leading-relaxed mb-5 line-clamp-3">
              {doc.description}
            </p>

            <!-- Meta Row -->
            <div class="flex items-center gap-4 mb-5 text-[10px] text-slate-400 font-bold uppercase tracking-wider">
              <span>{doc.pages} {doc.pages === 1 ? 'page' : 'pages'}</span>
              <span>{doc.filename.toUpperCase().endsWith('.DOCX') ? 'WORD' : 'PDF'}</span>
            </div>

            <!-- Download Link -->
            <a
              href={`${base}downloads/${doc.filename}`}
              download
              class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-[#001F5B] border-b border-[#001F5B]/30 pb-1 hover:border-[#001F5B] transition-colors"
            >
              <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Download
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Filter script -->
  <script is:inline>
    (function () {
      const bar   = document.getElementById('filter-bar');
      const grid  = document.getElementById('docs-grid');
      if (!bar || !grid) return;

      const cards = Array.from(grid.querySelectorAll('[data-category]'));

      bar.addEventListener('click', function (e) {
        const btn = e.target.closest('.filter-btn');
        if (!btn) return;

        const selected = btn.dataset.filter;

        // Update button styles
        bar.querySelectorAll('.filter-btn').forEach(function (b) {
          if (b === btn) {
            b.classList.add('bg-[#001F5B]', 'border-[#001F5B]', 'text-white');
            b.classList.remove('border-slate-200', 'text-slate-600', 'bg-white');
          } else {
            b.classList.remove('bg-[#001F5B]', 'border-[#001F5B]', 'text-white');
            b.classList.add('border-slate-200', 'text-slate-600', 'bg-white');
          }
        });

        // Show / hide cards
        cards.forEach(function (card) {
          if (selected === 'All' || card.dataset.category === selected) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    })();
  </script>

  <!-- CV Download CTA -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="bg-[#001F5B] p-10 flex flex-col md:flex-row items-center justify-between gap-8" data-reveal>
        <div>
          <h2 class="text-2xl font-black text-white mb-2">Download My CV</h2>
          <p class="text-white/70 text-sm">Full credentials, experience, and engagement history.</p>
        </div>
        <a
          href={`${base}cv/Majid-Mumtaz-Internal-Audit-Director-UAE-KSA-CV.pdf`}
          download
          class="flex-shrink-0 px-8 py-4 bg-white text-[#001F5B] font-black text-xs uppercase tracking-widest hover:bg-slate-100 transition-colors"
        >
          Download CV
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
