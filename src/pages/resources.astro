---
import BaseLayout from '../layouts/BaseLayout.astro';
import documents from '../data/documents.json';
import NetworkCanvas from '../components/NetworkCanvas';
import RiskAppetiteInfographic from '../components/RiskAppetiteInfographic.astro';
const base = import.meta.env.BASE_URL;

const categories = ['All', ...new Set((documents as any[]).map((d: any) => d.category))];
---

<BaseLayout
  title="Resources | Professional Internal Audit Downloads — Majid Mumtaz"
  description="Professional internal audit frameworks, checklists, guides, and tools. Download risk control matrices, fraud prevention guides, SOX implementation guides, and more."
>
  <section class="relative overflow-hidden px-4 pt-24 md:px-8 md:pt-28">
    <div class="editorial-panel relative mx-auto max-w-7xl overflow-hidden px-6 py-10 md:px-10 md:py-12">
      <NetworkCanvas client:load nodeCount={35} />
      <div class="relative z-10 max-w-4xl" data-reveal>
        <span class="hero-chip mb-8">Professional Downloads</span>
        <h1 class="headline-display max-w-4xl text-[clamp(3rem,7vw,6rem)] font-black text-white">
          Resources
          <span class="block text-[#f4c98b]">for practitioners</span>
          <span class="block">who need usable tools.</span>
        </h1>
        <p class="mt-8 max-w-3xl text-base leading-8 text-white/74 md:text-[1.1rem] md:leading-9">
          Complimentary frameworks, checklists, and guides for internal audit professionals. Structured for direct use, not content padding.
        </p>
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="soft-shell mx-auto max-w-7xl overflow-hidden px-7 py-8 md:px-10 md:py-10">
      <RiskAppetiteInfographic />
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10" data-reveal>
        <span class="eyebrow-label">Resource Library</span>
        <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-[#181511]">Downloadable frameworks and checklists.</h2>
      </div>

      <div class="mb-8 flex flex-wrap gap-2" id="filter-bar">
        {categories.map((cat, idx) => (
          <button
            data-filter={cat}
            class={`filter-btn rounded-full px-4 py-2 text-[10px] font-black uppercase tracking-[0.24em] border transition-all duration-150 ${idx === 0 ? 'bg-[#1d3557] border-[#1d3557] text-white' : 'border-[rgba(29,53,87,0.10)] text-[color:var(--text-secondary)] bg-white/60 hover:border-[#1d3557]/40 hover:text-[#181511]'}`}
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3" id="docs-grid">
        {(documents as any[]).map((doc: any, i: number) => (
          <div
            class="glass-card flex flex-col rounded-[30px] p-7"
            data-category={doc.category}
            data-reveal
            data-reveal-delay={String((i % 3) + 1)}
          >
            <div class="flex items-center justify-between gap-4 mb-5">
              <span class="rounded-full bg-[#a33a21]/8 px-3 py-1 text-[10px] font-black uppercase tracking-[0.24em] text-[#a33a21]">
                {doc.category}
              </span>
              <span class="meta-label text-slate-400">{doc.size}</span>
            </div>

            <h3 class="text-xl leading-tight text-[#181511] flex-1">
              {doc.title}
            </h3>

            <p class="mt-4 text-sm leading-8 text-[color:var(--text-secondary)]">
              {doc.description}
            </p>

            <div class="mt-5 flex items-center gap-4 text-[10px] font-black uppercase tracking-[0.22em] text-slate-400">
              <span>{doc.pages} {doc.pages === 1 ? 'page' : 'pages'}</span>
              <span>{doc.filename.toUpperCase().endsWith('.DOCX') ? 'WORD' : 'PDF'}</span>
            </div>

            <a
              href={`${base}downloads/${doc.filename}`}
              download
              class="mt-6 btn-secondary self-start"
            >
              Download
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const bar = document.getElementById('filter-bar');
      const grid = document.getElementById('docs-grid');
      if (!bar || !grid) return;

      const cards = Array.from(grid.querySelectorAll('[data-category]'));

      bar.addEventListener('click', function (e) {
        const btn = e.target.closest('.filter-btn');
        if (!btn) return;

        const selected = btn.dataset.filter;

        bar.querySelectorAll('.filter-btn').forEach(function (b) {
          if (b === btn) {
            b.classList.add('bg-[#1d3557]', 'border-[#1d3557]', 'text-white');
            b.classList.remove('text-[color:var(--text-secondary)]', 'bg-white/60');
          } else {
            b.classList.remove('bg-[#1d3557]', 'border-[#1d3557]', 'text-white');
            b.classList.add('text-[color:var(--text-secondary)]', 'bg-white/60');
          }
        });

        cards.forEach(function (card) {
          if (selected === 'All' || card.dataset.category === selected) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    })();
  </script>

  <section class="px-4 py-4 pb-10 md:px-8">
    <div class="editorial-panel mx-auto flex max-w-7xl flex-col items-start justify-between gap-8 px-7 py-10 md:flex-row md:items-center md:px-10" data-reveal>
      <div>
        <div class="meta-label text-[#f4c98b]">Executive CV</div>
        <h2 class="mt-3 text-3xl text-white">Download the full profile.</h2>
        <p class="mt-3 text-sm leading-8 text-white/68">Full credentials, experience, and engagement history.</p>
      </div>
      <a href={`${base}cv/Majid-Mumtaz-Internal-Audit-Director-CV.pdf`} download class="btn-secondary-light">Download CV</a>
    </div>
  </section>
</BaseLayout>
