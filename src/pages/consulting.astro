---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const advisoryTiers = [
  {
    id: 'ipo-mna',
    name: 'IPO & M&A Guardrail',
    tagline: 'High-Stakes Transactional Assurance',
    description: 'Specialised advisory for organisations at critical liquidity events. I provide the independent governance framework required to secure first-time clean opinions and protect M&A capital.',
    deliverables: [
      'ICOFR / SOX 404 Implementation',
      'M&A Forensic Due Diligence',
      'CMA / SCA Regulatory Compliance',
      'Listing Prospectus Governance Prep'
    ],
    idealFor: 'Pre-IPO Tech Firms, PE Portfolio Companies, Acquiring Groups',
    icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'
  },
  {
    id: 'audit-4',
    name: 'Audit 4.0 Transformation',
    tagline: 'Moving from Sampling to 100% Population Testing',
    description: 'Modernising legacy Internal Audit functions using Python and Machine Learning. I augment your existing team by building the automated tools they need to achieve real-time risk intelligence.',
    deliverables: [
      'Python/ML Forensic Risk Engine',
      'Continuous Monitoring Automation',
      'Data-Driven Fraud Detection',
      'Methodology Modernisation (IIA 2024)'
    ],
    idealFor: 'Established Audit Teams, High-Volume Transactional Businesses',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z'
  },
  {
    id: 'fractional-cae',
    name: 'Fractional CAE & Board Advisory',
    tagline: 'Strategic Governance Oversight on Retainer',
    description: 'Providing senior-level leadership for organizations that require a Chief Audit Executive or Board Advisor but aren’t ready for a full-time hire. Credible, independent, and board-facing.',
    deliverables: [
      'Audit Committee Advisory',
      'ERM / COSO Framework Design',
      'IA Function Build-Out (Scale 3 to 20+)',
      'Whistleblowing & Ethics Oversight'
    ],
    idealFor: 'Family Offices, Mid-Market GCC Groups, Scaling Unicorns',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
  }
];
---

<BaseLayout
  title="Executive Advisory | Majid Mumtaz — Strategic Internal Audit"
  description="Director-level advisory services: IPO readiness, M&A protection, Audit 4.0 transformation, and Fractional CAE support across the GCC and APAC."
>
  <!-- Hero -->
  <section class="pt-32 pb-24 bg-[#001F5B] relative overflow-hidden text-center">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#C9A84C 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
      <div class="max-w-3xl mx-auto" data-reveal>
        <span class="text-[10px] font-black uppercase tracking-[0.4em] text-[#C9A84C] mb-6 block">Strategic Advisory</span>
        <h1 class="text-5xl lg:text-7xl font-black text-white mb-8 leading-tight tracking-tighter">
          Augmenting <span class="text-[#C9A84C]">Governance.</span>
        </h1>
        <p class="text-xl text-white/70 leading-relaxed max-w-2xl mx-auto font-medium italic">
          "I provide the technical depth and independent board-grade validation that internal teams often lack the time to build."
        </p>
      </div>
    </div>
  </section>

  <!-- Executive Tiers -->
  <section class="py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="space-y-12">
        {advisoryTiers.map((tier, i) => (
          <div 
            class="flex flex-col lg:flex-row border border-slate-200 group hover:border-[#C9A84C]/50 transition-all duration-500 shadow-sm hover:shadow-2xl bg-white"
            data-reveal
            data-reveal-delay={String(i + 1)}
          >
            {/* Tier Label & Name */}
            <div class="w-full lg:w-[400px] bg-slate-50 p-10 lg:p-12 flex flex-col justify-between border-b lg:border-b-0 lg:border-r border-slate-200 group-hover:bg-white transition-colors duration-500">
              <div>
                <div class="flex items-center gap-4 mb-8">
                  <div class="w-12 h-12 bg-[#001F5B] flex items-center justify-center text-white shadow-lg group-hover:bg-[#C9A84C] group-hover:text-[#001F5B] transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tier.icon}/>
                    </svg>
                  </div>
                  <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#8895AA]">Tier 0{i+1}</span>
                </div>
                <h3 class="text-3xl font-black text-[#001F5B] mb-2 leading-tight tracking-tighter">{tier.name}</h3>
                <p class="text-[#C9A84C] text-xs font-black uppercase tracking-widest">{tier.tagline}</p>
              </div>
              <div class="mt-10">
                <a href={`${base}contact/`} class="inline-flex items-center gap-3 text-[10px] font-black uppercase tracking-[0.2em] text-[#001F5B] hover:text-[#C9A84C] transition-colors">
                  Initiate Inquiry
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>

            {/* Tier Details */}
            <div class="flex-1 p-10 lg:p-12 flex flex-col justify-between">
              <div>
                <p class="text-slate-600 text-lg leading-relaxed mb-10 font-medium max-w-2xl">
                  {tier.description}
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                  <div>
                    <span class="text-[10px] font-black uppercase tracking-widest text-[#8895AA] block mb-4 border-b border-slate-100 pb-2">Core Deliverables</span>
                    <ul class="space-y-3">
                      {tier.deliverables.map(item => (
                        <li class="flex items-start gap-3 text-sm text-slate-800 font-bold">
                          <span class="w-1.5 h-1.5 bg-[#C9A84C] mt-1.5 flex-shrink-0"></span>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="bg-slate-50 p-6 border-l-2 border-[#C9A84C]">
                    <span class="text-[10px] font-black uppercase tracking-widest text-[#8895AA] block mb-2">Ideal Engagement Context</span>
                    <p class="text-xs text-[#001F5B] font-black leading-relaxed italic uppercase tracking-tight">
                      {tier.idealFor}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The "Independent Edge" Section -->
  <section class="py-32 bg-[#001F5B] text-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div data-reveal>
          <span class="text-[10px] font-black uppercase tracking-[0.4em] text-[#C9A84C] mb-6 block">Why Independent?</span>
          <h2 class="text-4xl lg:text-5xl font-black mb-8 leading-tight">The Board-Grade Independent Edge.</h2>
          <p class="text-white/70 text-lg leading-relaxed mb-8">
            Large firms bring teams; I bring **judgment**. As a senior leader who has scaled functions from zero to 20+ professionals, I know that the hardest part of audit is moving from compliance-ticking to strategic value protection.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="p-6 border border-white/10 bg-white/5">
              <h4 class="text-[#C9A84C] font-black text-sm mb-2 uppercase tracking-widest italic">Direct Board Accountability</h4>
              <p class="text-xs text-white/60">No junior middle-men. You work directly with a 20+ year expert who has sat on Audit Committees.</p>
            </div>
            <div class="p-6 border border-white/10 bg-white/5">
              <h4 class="text-[#C9A84C] font-black text-sm mb-2 uppercase tracking-widest italic">Tech-First Methodology</h4>
              <p class="text-xs text-white/60">I build proprietary Python/ML tools that remain yours, enabling 100% population testing.</p>
            </div>
          </div>
        </div>
        <div class="relative group" data-reveal data-reveal-delay="1">
          <div class="absolute inset-0 bg-[#C9A84C]/20 blur-3xl rounded-full scale-75 group-hover:scale-100 transition-transform duration-700"></div>
          <div class="relative bg-[#000F2E] border border-white/10 p-10 lg:p-16 shadow-2xl">
            <div class="flex flex-col items-center text-center">
              <span class="text-[60px] font-black text-[#C9A84C] leading-none mb-4">20+</span>
              <span class="text-xs font-black uppercase tracking-[0.5em] text-white/40 mb-8">Years of GCC Experience</span>
              <div class="flex flex-wrap justify-center gap-2 mb-10">
                {['CIA', 'ACA', 'FCCA', 'COSO ERM'].map(cert => (
                  <span class="text-[9px] font-black px-3 py-1 border border-white/20 uppercase tracking-widest">{cert}</span>
                ))}
              </div>
              <a href={`${base}contact/`} class="btn-primary w-full">Request Executive Briefing</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center" data-reveal>
      <h2 class="text-4xl font-black text-[#001F5B] mb-6 tracking-tighter">Ready to Discussion?</h2>
      <p class="text-slate-500 text-lg mb-10 max-w-xl mx-auto font-medium">
        Every advisory engagement starts with a high-level context briefing to align on strategic objectives.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${base}contact/`} class="btn-primary">Initiate Strategic Consultation</a>
        <a href={`${base}projects/`} class="border border-[#001F5B] text-[#001F5B] px-8 py-4 text-xs font-black uppercase tracking-widest hover:bg-[#001F5B] hover:text-white transition-all">Review Case Studies</a>
      </div>
    </div>
  </section>
</BaseLayout>
