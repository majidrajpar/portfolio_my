---
import BaseLayout from '../layouts/BaseLayout.astro';
import NetworkCanvas from '../components/NetworkCanvas';
import { getAdvisoryTiers } from '../lib/db.js';

const advisoryTiers = getAdvisoryTiers();
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Executive Advisory | Majid Mumtaz — Strategic Internal Audit"
  description="Director-level advisory services: IPO readiness, M&A protection, Audit 4.0 transformation, and retained CAE board advisory for boards and leadership teams globally."
>
  <section class="relative overflow-hidden px-4 pt-24 md:px-8 md:pt-28">
    <div class="editorial-panel relative mx-auto max-w-7xl overflow-hidden px-6 py-10 text-center md:px-10 md:py-12">
      <NetworkCanvas client:load nodeCount={35} />
      <div class="relative z-10 mx-auto max-w-4xl" data-reveal>
        <span class="hero-chip mb-8">Strategic Advisory</span>
        <h1 class="headline-display text-[clamp(3rem,7vw,6.4rem)] font-black text-white">
          Augmenting
          <span class="block text-[#f4c98b]">governance</span>
          <span class="block">when it matters.</span>
        </h1>
        <p class="mt-8 mx-auto max-w-3xl text-base leading-8 text-white/74 md:text-[1.1rem] md:leading-9">
          Technical depth and independent board-grade validation for organisations that cannot build the capability fast enough in-house.
        </p>
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="mx-auto max-w-7xl space-y-6">
      {advisoryTiers.map((tier, i) => (
        <div class="glass-card overflow-hidden rounded-[34px]" data-reveal data-reveal-delay={String(i + 1)}>
          <div class="grid lg:grid-cols-[0.9fr_1.1fr]">
            <div class="editorial-panel px-8 py-10 md:px-10">
              <div class="relative z-10 flex h-full flex-col justify-between">
                <div>
                  <div class="flex items-center gap-4 mb-8">
                    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white/10 text-white border border-white/10">
                      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tier.icon}/>
                      </svg>
                    </div>
                    <span class="meta-label text-[#f4c98b]">Tier 0{i + 1}</span>
                  </div>
                  <h2 class="text-3xl leading-tight text-white">{tier.name}</h2>
                  <p class="mt-3 text-[11px] font-black uppercase tracking-[0.24em] text-white/46">{tier.tagline}</p>
                </div>
                <div class="mt-10">
                  <a href={`${base}contact/`} class="btn-secondary-light">Start the Conversation</a>
                </div>
              </div>
            </div>

            <div class="soft-shell rounded-none px-8 py-10 md:px-10">
              <p class="body-luxe max-w-3xl">{tier.description}</p>
              <div class="mt-8 grid gap-5 md:grid-cols-[1.1fr_0.9fr]">
                <div class="stat-plinth p-6">
                  <div class="meta-label text-[#a33a21]">Core Deliverables</div>
                  <ul class="mt-4 space-y-3">
                    {tier.deliverables.map((item) => (
                      <li class="flex items-start gap-3 text-sm font-semibold leading-7 text-[#181511]">
                        <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[#c7964c]"></span>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="quote-panel p-6">
                  <div class="meta-label text-[#1d3557]">Ideal Engagement Context</div>
                  <p class="mt-4 text-sm leading-8 text-[#1b1a17]">{tier.idealFor}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="soft-shell mx-auto max-w-7xl px-7 py-10 md:px-10 md:py-12" data-reveal>
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <span class="eyebrow-label">How Engagements Work</span>
          <h2 class="mt-4 text-[clamp(1.8rem,3.5vw,3rem)] leading-[1.05] text-[#181511]">Structure before scope.</h2>
          <p class="body-luxe mt-5 max-w-2xl">
            Engagements typically run 3 to 6 months, structured around a defined deliverable: a completed audit plan, a reviewed control environment, a transaction diligence workstream, or a quarterly retained advisory cycle. They can extend where continuity adds value. All mandates are executed directly — not delegated to a junior layer.
          </p>
          <p class="body-luxe mt-4 max-w-2xl">
            The engagement starts with a scoping conversation. If the fit is right, a statement of work is issued within one week. No retainers before scope is agreed.
          </p>
        </div>
        <div class="grid gap-4">
          {[['3–6 months', 'Typical engagement duration'], ['Direct execution', 'No delegation to juniors'], ['Defined deliverable', 'Scope agreed before engagement starts'], ['Board-grade output', 'Findings structured for executive and AC use']].map(([stat, label]) => (
            <div class="stat-plinth p-5 flex items-center gap-5">
              <div class="text-xl font-black text-[#a33a21] leading-none min-w-[100px]">{stat}</div>
              <div class="text-sm text-[color:var(--text-secondary)] leading-6">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-4 md:px-8">
    <div class="editorial-panel mx-auto max-w-7xl px-7 py-10 md:px-10 md:py-12">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.92fr]">
        <div data-reveal>
          <span class="meta-label text-[#f4c98b]">Why Independent</span>
          <h2 class="mt-4 text-[clamp(2rem,4.5vw,3.8rem)] leading-[1.02] text-white">The board-grade independent edge.</h2>
          <p class="mt-6 max-w-2xl text-base leading-8 text-white/70">
            Large firms bring teams. This model brings direct judgment from someone who has built functions from zero, scaled them, and dealt with the political and structural realities that generic methodologies gloss over.
          </p>
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            <div class="frame-panel p-6">
              <div class="meta-label text-[#f4c98b]">Direct Board Accountability</div>
              <p class="mt-4 text-sm leading-8 text-white/70">No junior relay layer. You work directly with a senior operator who understands audit committees, executive tension, and control design under pressure.</p>
            </div>
            <div class="frame-panel p-6">
              <div class="meta-label text-[#f4c98b]">Tech-Enabled Methodology</div>
              <p class="mt-4 text-sm leading-8 text-white/70">Python-driven tooling, analytics-first testing, and population-based approaches designed to remain useful after the engagement ends.</p>
            </div>
          </div>
        </div>

        <div class="frame-panel p-8 text-center" data-reveal data-reveal-delay="1">
          <div class="text-6xl font-black leading-none text-[#f4c98b]">20+</div>
          <div class="mt-3 meta-label text-white/40">Years Experience</div>
          <div class="mt-8 flex flex-wrap justify-center gap-2">
            {['CIA', 'ACA', 'FCCA', 'COSO ERM'].map((cert) => (
              <span class="hero-chip">{cert}</span>
            ))}
          </div>
          <div class="mt-10">
            <a href={`${base}contact/`} class="btn-primary">Start the Conversation</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
