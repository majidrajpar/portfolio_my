---
import '../styles/global.css';
import Navbar from '../components/Navbar';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Director of Internal Audit with 20+ years finding the operational and governance gaps businesses have not priced yet. Fraud detection, board-grade assurance, and audit functions that actually protect capital.',
  ogImage = '/portfolio_my/images/majid-profile.jpg'
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="author" content="Majid Mumtaz" />
  <meta name="description" content={description} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://majidrajpar.github.io${ogImage}`} />
  <meta property="og:site_name" content="Majid Mumtaz | Chief Audit Executive" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://majidrajpar.github.io${ogImage}`} />

  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <title>{title}</title>

  <!-- Structured data: Person schema -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Majid Mumtaz",
    "givenName": "Majid",
    "familyName": "Mumtaz",
    "jobTitle": "Director of Internal Audit",
    "url": "https://majidrajpar.github.io/portfolio_my/",
    "image": "https://majidrajpar.github.io/portfolio_my/images/majid-profile.jpg",
    "email": "mailto:majidrajpar@gmail.com",
    "description": "Director of Internal Audit with 20+ years in Big 4 and GCC leadership. CIA, ACA, FCCA. Published in IIA, GRC Report, Consultancy ME, and Corporate Compliance Insights.",
    "knowsAbout": [
      "Internal Audit",
      "Fraud Detection",
      "Forensic Analytics",
      "IPO Readiness",
      "Board Governance",
      "COSO ERM",
      "ICOFR",
      "Risk Management"
    ],
    "hasCredential": ["CIA", "ACA", "FCCA", "COSO ERM Certified"],
    "alumniOf": [
      { "@type": "Organization", "name": "Ernst & Young" },
      { "@type": "Organization", "name": "KPMG" }
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Dubai",
      "addressCountry": "AE"
    },
    "sameAs": [
      "https://www.linkedin.com/in/majid-m-4b097118/",
      "https://www.youtube.com/@AuditBitz",
      "https://majidmumtaz.substack.com/",
      "https://veritux.com/consultants/majid-mumtaz/",
      "https://app.gocatalant.com/c/_/profile/kd6vrg/verify/"
    ]
  })} />

  <ViewTransitions />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />

  <!-- Google Analytics GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-9GCK25N9C5"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-9GCK25N9C5');
  </script>
</head>
<body class="min-h-screen">

  <!-- Skip to main content (keyboard/screen-reader users) -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-white focus:text-[#001F5B] focus:font-black focus:text-xs focus:uppercase focus:tracking-widest focus:border focus:border-[#001F5B] focus:outline-none">
    Skip to main content
  </a>

  <!-- Navbar: React island for scroll-aware behaviour -->
  <Navbar client:load />

  <!-- Main Content -->
  <main id="main-content">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer-shell py-16 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-4 mb-14">
        <!-- Brand -->
        <div class="md:col-span-2">
          <div class="text-white font-black text-xs uppercase tracking-[0.34em] mb-4">Majid Mumtaz</div>
          <p class="text-white/70 text-sm leading-7 max-w-sm">
            Director of Internal Audit | Board & C-Suite Advisory. 20+ years building audit functions boards actually act on.
          </p>
          <div class="flex gap-5 mt-6">
            <a href="https://www.linkedin.com/in/majid-m-4b097118/" target="_blank" rel="noopener noreferrer"
               class="text-white/60 hover:text-white text-[10px] font-black uppercase tracking-[0.28em] transition-colors">LinkedIn ↗</a>
            <a href="https://www.linkedin.com/newsletters/7339153291630510080/" target="_blank" rel="noopener noreferrer"
               class="text-white/60 hover:text-white text-[10px] font-black uppercase tracking-[0.28em] transition-colors">Newsletter ↗</a>
          </div>
        </div>
        <!-- Pages -->
        <div>
          <div class="text-white/45 text-[10px] font-black uppercase tracking-[0.28em] mb-5">Pages</div>
          <ul class="space-y-3">
            {[
              { label: 'About', href: `${base}/about/` },
              { label: 'Projects', href: `${base}/projects/` },
              { label: 'Advisory', href: `${base}/consulting/` },
              { label: 'Books', href: `${base}/about/#books` },
              { label: 'Newsletter', href: 'https://www.linkedin.com/newsletters/7339153291630510080/' },
              { label: 'Resources', href: `${base}/resources/` },
              { label: 'Tools', href: `${base}/tools/` },
              { label: 'Contact', href: `${base}/contact/` },
            ].map(link => (
              <li><a href={link.href} class="text-white/72 hover:text-white text-sm font-semibold transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>
        <!-- Contact -->
        <div>
          <div class="text-white/45 text-[10px] font-black uppercase tracking-[0.28em] mb-5">Contact</div>
          <ul class="space-y-3">
            <li><a href="mailto:majidrajpar@gmail.com" class="text-white/72 hover:text-white text-sm font-semibold transition-colors">majidrajpar@gmail.com</a></li>
            <li><span class="text-white/72 text-sm font-semibold">Dubai, UAE</span></li>
            <li><a href={`${base}/cv/Majid-Mumtaz-Internal-Audit-Director-CV.pdf`} download class="text-white/72 hover:text-white text-sm font-semibold transition-colors">Download CV</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10 pt-7 text-center">
        <div class="text-white/45 text-[9px] uppercase tracking-[0.42em] font-black">
          &copy; {new Date().getFullYear()} Majid Mumtaz CIA, ACA, FCCA. All Rights Reserved.
        </div>
      </div>
    </div>
  </footer>

  <!-- IntersectionObserver for data-reveal animations -->
  <!-- astro:page-load fires on initial load AND after every View Transitions navigation -->
  <script is:inline>
    document.addEventListener('astro:page-load', function() {
      const io = new IntersectionObserver(
        function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              io.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '-60px' }
      );
      document.querySelectorAll('[data-reveal]').forEach(function(el) {
        io.observe(el);
      });
    });
  </script>

</body>
</html>
